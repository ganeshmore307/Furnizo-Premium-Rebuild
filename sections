  .faz-testi-loc { font-size: 12px; color: #8a7d74; }
  .faz-testi-dots { display:flex; justify-content:center; gap:8px; margin-top: 22px; }
  .faz-testi-dots span { width:7px; height:7px; border-radius:50%; background:#d9cbc5; display:inline-block; cursor:pointer; }
  .faz-testi-dots span.faz-active { background:#6b1f2a; }
</style>

<script>
  (function(){
    document.querySelectorAll('.faz-testi').forEach(function(root){
      var track = root.querySelector('.faz-testi-track');
      var slides = root.querySelectorAll('.faz-testi-slide');
      var dotsWrap = root.querySelector('.faz-testi-dots');
      var index = 0;
      slides.forEach(function(_, i){ var d = document.createElement('span'); if (i === 0) d.classList.add('faz-active'); d.addEventListener('click', function(){ go(i); }); dotsWrap.appendChild(d); });
      function go(i){ index = (i + slides.length) % slides.length; track.style.transform = 'translateX(-' + (index * 100) + '%)'; track.style.transition = 'transform .5s ease'; dotsWrap.querySelectorAll('span').forEach(function(d, di){ d.classList.toggle('faz-active', di === index); }); }
      track.style.width = (slides.length * 100) + '%';
      slides.forEach(function(s){ s.style.width = (100 / slides.length) + '%'; });
      if (root.dataset.autoplay === 'true' && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) { setInterval(function(){ go(index + 1); }, (parseInt(root.dataset.speed, 10) || 5) * 1000); }
    });
  })();
</script>

