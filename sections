      setupScrollState() {
        const update = () => this.classList.toggle('is-scrolled', window.scrollY > 8);
        update();
        window.addEventListener('scroll', update, { passive: true, signal: this.signal });
      }

      setupOutsideClick() {
        document.addEventListener('pointerdown', (event) => {
          if (!this.contains(event.target)) {
            this.searchInstances.forEach((instance) => instance.close());
          }
        }, { signal: this.signal });
      }

      setupThemeEditor() {
        document.addEventListener('shopify:block:select', (event) => {
          const item = event.target.closest && event.target.closest('[data-announcement-item]');
          if (!item || !this.contains(item)) return;
          const index = Number(item.dataset.announcementIndex || 0);
          this.stopAnnouncements();
          this.showAnnouncement(index);
        }, { signal: this.signal });

        document.addEventListener('shopify:block:deselect', (event) => {
          if (this.contains(event.target)) this.startAnnouncements();
        }, { signal: this.signal });
      }
    }

    if (!customElements.get('premium-header')) {
      customElements.define('premium-header', PremiumHeader);
    }
  })();
