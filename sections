{%- liquid
  assign section_id = 'ShopCategory-' | append: section.id
  assign desktop_gap_total = section.settings.desktop_cards | minus: 1 | times: section.settings.desktop_gap
  assign laptop_gap_total = section.settings.laptop_cards | minus: 1 | times: section.settings.desktop_gap
  assign tablet_gap_total = section.settings.tablet_cards | minus: 1 | times: section.settings.desktop_gap
  assign image_loading = 'lazy'
  unless section.settings.lazy_load
    assign image_loading = 'eager'
  endunless
  assign image_zoom = section.settings.image_zoom | divided_by: 100.0
-%}

<style>
  #{{ section_id }} {
    --container: {{ section.settings.container_width }}px;
    --gap: {{ section.settings.desktop_gap }}px;
    --mobile-gap: {{ section.settings.mobile_gap }}px;
    --desktop-card: calc((100% - {{ desktop_gap_total }}px) / {{ section.settings.desktop_cards }});
    --laptop-card: calc((100% - {{ laptop_gap_total }}px) / {{ section.settings.laptop_cards }});
    --tablet-card: calc((100% - {{ tablet_gap_total }}px) / {{ section.settings.tablet_cards }});
    --mobile-card: {{ section.settings.mobile_card_width }}vw;
    --image-height: {{ section.settings.image_height_desktop }}px;
    --mobile-image-height: {{ section.settings.image_height_mobile }}px;
    --image-radius: {{ section.settings.image_radius }}px;
    --image-zoom: {{ image_zoom }};
    --card-radius: {{ section.settings.card_radius }}px;
    --transition: {{ section.settings.transition_speed }}ms;

    width: 100%;
    max-width: 100%;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    background: {{ section.settings.section_background }};
  }

  #{{ section_id }},
  #{{ section_id }} * {
    box-sizing: border-box;
  }

  #{{ section_id }} .sc-container {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
  }

  #{{ section_id }}.sc-full .sc-container {
    max-width: none;
  }

  #{{ section_id }} .sc-header {
    display: flex;
    margin-bottom: 24px;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  #{{ section_id }} .sc-heading {
    width: 100%;
    margin: 0;
    color: {{ section.settings.heading_color }};
    font-family: var(--font-heading-family, Georgia, 'Times New Roman', serif);
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: 400;
    letter-spacing: {{ section.settings.heading_spacing }}px;
    line-height: 1.2;
    text-align: {{ section.settings.heading_alignment }};
    text-transform: uppercase;
  }

  #{{ section_id }} .sc-navigation {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 8px;
  }

  #{{ section_id }} .sc-nav {
    display: inline-flex;
    width: {{ section.settings.nav_size }}px;
    height: {{ section.settings.nav_size }}px;
    padding: 0;
    align-items: center;
    justify-content: center;
    border: 1px solid {{ section.settings.nav_border }};
    border-radius: 50%;
    background: {{ section.settings.nav_background }};
    color: {{ section.settings.nav_color }};
    cursor: pointer;
    transition:
      color 250ms ease,
      background-color 250ms ease,
      transform 250ms ease;
  }

  #{{ section_id }} .sc-nav:hover,
  #{{ section_id }} .sc-nav:focus-visible {
    background: {{ section.settings.nav_hover_background }};
    color: {{ section.settings.nav_hover_color }};
    transform: translateY(-2px);
  }

  #{{ section_id }} .sc-nav:focus-visible {
    outline: 2px solid {{ section.settings.nav_hover_background }};
    outline-offset: 2px;
  }

  #{{ section_id }} .sc-nav svg {
    width: 45%;
    height: 45%;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  #{{ section_id }} .sc-track {
    display: flex;
    width: 100%;
    max-width: 100%;
    padding: 7px 2px 16px;
    align-items: stretch;
    gap: var(--gap);
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-inline: contain;
    scroll-padding-inline: 2px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    touch-action: pan-x pan-y;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
  }

  #{{ section_id }} .sc-track::-webkit-scrollbar {
    display: none;
  }

  #{{ section_id }} .sc-track.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    user-select: none;
  }

  #{{ section_id }} .sc-card {
    position: relative;
    display: flex;
    min-width: 0;
    flex: 0 0 var(--desktop-card);
    flex-direction: column;
    align-self: stretch;
    overflow: hidden;
    scroll-snap-align: start;
    scroll-snap-stop: always;

    border:
      {% if section.settings.show_border %}
        1px solid {{ section.settings.border_color }}
      {% else %}
        0
      {% endif %};

    border-radius: var(--card-radius);
    background: {{ section.settings.card_background }};

    box-shadow:
      {% if section.settings.card_shadow %}
        0 8px 26px rgba(39, 25, 20, 0.09)
      {% else %}
        none
      {% endif %};

    color: inherit;
    text-decoration: none;
    transform: translateY(0);

    transition:
      transform var(--transition) ease,
      box-shadow var(--transition) ease;
  }

  #{{ section_id }} .sc-card:hover {
    box-shadow:
      {% if section.settings.hover_shadow %}
        0 16px 42px rgba(39, 25, 20, 0.16)
      {% else %}
        none
      {% endif %};

    transform: translateY(-{{ section.settings.hover_lift }}px);
  }

  #{{ section_id }} .sc-card:focus-visible {
    outline: 2px solid {{ section.settings.title_hover_color }};
    outline-offset: 3px;
  }

  #{{ section_id }} .sc-media {
    position: relative;
    display: block;
    width: 100%;
    height: var(--image-height);
    overflow: hidden;
    flex: 0 0 auto;
    border-radius: var(--image-radius);
    background: #f4f1ed;
  }

  #{{ section_id }} .sc-image,
  #{{ section_id }} .sc-placeholder,
  #{{ section_id }} .sc-media picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  #{{ section_id }} .sc-image {
    object-fit: {{ section.settings.image_fit }};
    object-position: center;
    transform: scale(1);

    transition:
      transform var(--transition)
      cubic-bezier(0.22, 1, 0.36, 1);
  }

  #{{ section_id }} .sc-placeholder {
    background: #f4f1ed;
    color: #d8cec6;
  }

  #{{ section_id }} .sc-card:hover .sc-image {
    transform: scale(var(--image-zoom));
  }

  #{{ section_id }} .sc-title-row {
    display: flex;
    min-height: 44px;
    padding: 13px 7px 5px;
    align-items: center;
    gap: 8px;
    color: {{ section.settings.title_color }};
    font-family: var(--font-body-family, Arial, Helvetica, sans-serif);
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: {{ section.settings.title_weight }};
    letter-spacing: 0.04em;
    line-height: 1.35;
    text-transform: uppercase;
    transition: color var(--transition) ease;
  }

  #{{ section_id }} .sc-card:hover .sc-title-row {
    color: {{ section.settings.title_hover_color }};
  }

  #{{ section_id }} .sc-arrow {
    display: inline-flex;
    width: 16px;
    height: 16px;
    flex: 0 0 16px;
    transform: translateX(0);
    transition: transform var(--transition) ease;
  }

  #{{ section_id }} .sc-arrow svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.5;
  }

