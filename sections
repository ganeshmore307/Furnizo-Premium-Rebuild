<luxury-hero-banner
  id="LuxuryHeroBanner-{{ section.id }}"
  class="
    luxury-hero
    luxury-hero--{{ section.settings.section_width }}
    luxury-hero--{{ section.settings.transition_effect }}
    luxury-hero--fit-{{ section.settings.image_fit }}
    {% if adaptive_height %}luxury-hero--adaptive{% endif %}
    {% if section.settings.image_fit == 'natural' %}luxury-hero--natural{% endif %}
    {% if section.settings.image_shadow %}luxury-hero--shadow{% endif %}
  "
  data-slider
  data-slide-count="{{ slide_count }}"
  data-autoplay="{{ section.settings.enable_autoplay }}"
  data-autoplay-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  data-pause-hover="{{ section.settings.pause_on_hover }}"
  data-infinite="{{ section.settings.infinite_loop }}"
  data-effect="{{ section.settings.transition_effect }}"
  data-transition-speed="{{ section.settings.transition_speed }}"
  data-keyboard="{{ section.settings.keyboard_navigation }}"
  data-touch-swipe="{{ section.settings.touch_swipe }}"
  data-mouse-drag="{{ section.settings.mouse_drag }}"
  data-adaptive="{{ adaptive_height }}"
  data-desktop-min-height="{{ section.settings.desktop_min_height }}"
  data-mobile-min-height="{{ section.settings.mobile_min_height }}"
  data-arrow-position="{{ section.settings.arrow_position }}"
  data-dots-position="{{ section.settings.dots_position }}"
  role="region"
  aria-roledescription="carousel"
  aria-label="{{ section.settings.accessibility_label | escape }}"
  tabindex="0"
>
  <div class="luxury-hero__slider">
    <div class="luxury-hero__viewport" data-slider-viewport>
      <div class="luxury-hero__track" data-slider-track>
        {% for block in section.blocks %}
          {% liquid
            assign desktop_image = block.settings.desktop_image
            assign mobile_image = block.settings.mobile_image
            assign primary_image = desktop_image | default: mobile_image
            assign banner_alt = block.settings.alt_text

            if banner_alt == blank and primary_image != blank
              assign banner_alt = primary_image.alt
            endif

            if banner_alt == blank
              assign banner_alt = shop.name
            endif

            if forloop.first
              assign image_loading = 'eager'
              assign image_priority = 'high'
            elsif section.settings.lazy_load_images
              assign image_loading = 'lazy'
              assign image_priority = 'auto'
            else
              assign image_loading = 'eager'
              assign image_priority = 'auto'
            endif
          %}

          <div
            class="luxury-hero__slide{% if forloop.first %} is-active{% endif %}"
            data-slide
            data-slide-index="{{ forloop.index0 }}"
            data-block-id="{{ block.id }}"
            role="group"
            aria-roledescription="slide"
            aria-label="{{ forloop.index }} of {{ slide_count }}"
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            style="
              --lhb-desktop-position: {{ block.settings.desktop_position }};
              --lhb-mobile-position: {{ block.settings.mobile_position }};
            "
            {{ block.shopify_attributes }}
          >
            {% if block.settings.banner_link != blank %}
              <a
                class="luxury-hero__media-link"
                href="{{ block.settings.banner_link }}"
                aria-label="{{ banner_alt | escape }}"
                {% if block.settings.open_new_tab %}
                  target="_blank"
                  rel="noopener noreferrer"
                {% endif %}
                {% unless forloop.first %}tabindex="-1"{% endunless %}
                data-slide-link
              >
            {% else %}
              <div class="luxury-hero__media">
            {% endif %}

            {% if primary_image != blank %}
              <picture class="luxury-hero__picture">
                {% if mobile_image != blank %}
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {{ mobile_image | image_url: width: 375 }} 375w,
                      {{ mobile_image | image_url: width: 550 }} 550w,
                      {{ mobile_image | image_url: width: 750 }} 750w,
                      {{ mobile_image | image_url: width: 900 }} 900w,
                      {{ mobile_image | image_url: width: 1100 }} 1100w,
                      {{ mobile_image | image_url: width: 1500 }} 1500w
                    "
                    sizes="100vw"
                  >
                {% endif %}

                <img
                  class="luxury-hero__image"
                  src="{{ primary_image | image_url: width: 1800 }}"
                  srcset="
                    {{ primary_image | image_url: width: 550 }} 550w,
                    {{ primary_image | image_url: width: 750 }} 750w,
                    {{ primary_image | image_url: width: 1100 }} 1100w,
                    {{ primary_image | image_url: width: 1500 }} 1500w,
                    {{ primary_image | image_url: width: 1800 }} 1800w,
                    {{ primary_image | image_url: width: 2200 }} 2200w,
                    {{ primary_image | image_url: width: 2800 }} 2800w,
                    {{ primary_image | image_url: width: 3200 }} 3200w,
                    {{ primary_image | image_url: width: 3840 }} 3840w
                  "
                  sizes="{% if section.settings.section_width == 'boxed' %}(min-width: {{ section.settings.container_width }}px) {{ section.settings.container_width }}px, 100vw{% else %}100vw{% endif %}"
                  width="{{ primary_image.width }}"
                  height="{{ primary_image.height }}"
                  alt="{{ banner_alt | escape }}"
                  loading="{{ image_loading }}"
                  fetchpriority="{{ image_priority }}"
                  decoding="async"
                  draggable="false"
                >
              </picture>
            {% else %}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'luxury-hero__placeholder' }}
            {% endif %}

            {% if block.settings.banner_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if slide_count > 1 and section.settings.show_arrows %}
        <button
          class="luxury-hero__arrow luxury-hero__arrow--previous"
          type="button"
          aria-label="Previous slide"
          data-slider-previous
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m15 5-7 7 7 7"></path>
          </svg>
        </button>

        <button
          class="luxury-hero__arrow luxury-hero__arrow--next"
          type="button"
          aria-label="Next slide"
          data-slider-next
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m9 5 7 7-7 7"></path>
          </svg>
        </button>
      {% endif %}

      {% if slide_count > 1
        and section.settings.show_dots
        and section.settings.dots_position == 'inside_bottom'
      %}
        <div
          class="luxury-hero__dots"
          role="tablist"
          aria-label="Choose slide"
          data-slider-dots
        >
          {% for block in section.blocks %}
            <button
              class="luxury-hero__dot{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="tab"
              aria-label="Go to slide {{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              data-slider-dot="{{ forloop.index0 }}"
            ></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {% if slide_count > 1
      and section.settings.show_dots
      and section.settings.dots_position == 'below'
    %}
      <div
        class="luxury-hero__dots"
        role="tablist"
        aria-label="Choose slide"
        data-slider-dots
      >
        {% for block in section.blocks %}
          <button
            class="luxury-hero__dot{% if forloop.first %} is-active{% endif %}"
            type="button"
            role="tab"
            aria-label="Go to slide {{ forloop.index }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            data-slider-dot="{{ forloop.index0 }}"
          ></button>
        {% endfor %}
      </div>
    {% endif %}

    <div
      class="luxury-hero__live-region"
      aria-live="polite"
      aria-atomic="true"
      data-slider-live
    ></div>
  </div>
</luxury-hero-banner>

<script>
  if (!customElements.get('luxury-hero-banner')) {
    class LuxuryHeroBanner extends HTMLElement {
      constructor() {
        super();

        this.currentIndex = 0;
        this.positionIndex = 0;
        this.autoplayTimer = null;
        this.pointerStartX = 0;
        this.pointerDeltaX = 0;
        this.isPointerActive = false;
        this.hasDragged = false;
        this.suppressClick = false;
        this.resizeObserver = null;
        this.isConnectedSlider = false;

        this.handleVisibilityChange =
          this.handleVisibilityChange.bind(this);
        this.handleKeydown = this.handleKeydown.bind(this);
        this.handlePointerDown = this.handlePointerDown.bind(this);
        this.handlePointerMove = this.handlePointerMove.bind(this);
        this.handlePointerUp = this.handlePointerUp.bind(this);
        this.handlePointerCancel = this.handlePointerCancel.bind(this);
        this.handleTransitionEnd = this.handleTransitionEnd.bind(this);
        this.handleClickCapture = this.handleClickCapture.bind(this);
        this.handleResize = this.handleResize.bind(this);
        this.handleBlockSelect = this.handleBlockSelect.bind(this);
      }

      connectedCallback() {
        if (this.isConnectedSlider) return;

        this.viewport = this.querySelector('[data-slider-viewport]');
        this.track = this.querySelector('[data-slider-track]');
        this.previousButton = this.querySelector(
          '[data-slider-previous]'
        );
        this.nextButton = this.querySelector('[data-slider-next]');
        this.liveRegion = this.querySelector('[data-slider-live]');

        this.originalSlides = Array.from(
          this.querySelectorAll('[data-slide]:not([data-clone])')
        );

        this.dotButtons = Array.from(
          this.querySelectorAll('[data-slider-dot]')
        );

        this.slideCount = this.originalSlides.length;
        this.effect = this.dataset.effect || 'slide';
        this.infinite = this.dataset.infinite === 'true';
        this.autoplayEnabled = this.dataset.autoplay === 'true';
        this.autoplaySpeed =
          Number(this.dataset.autoplaySpeed) || 5000;
        this.pauseOnHover = this.dataset.pauseHover === 'true';
        this.keyboardEnabled = this.dataset.keyboard === 'true';
        this.touchSwipeEnabled = this.dataset.touchSwipe === 'true';
        this.mouseDragEnabled = this.dataset.mouseDrag === 'true';
        this.adaptiveHeight = this.dataset.adaptive === 'true';
        this.transitionSpeed =
          Number(this.dataset.transitionSpeed) || 600;

        if (!this.viewport || !this.track || this.slideCount === 0) {
          return;
        }

        this.isConnectedSlider = true;

        if (
          this.effect === 'slide' &&
          this.infinite &&
          this.slideCount > 1
        ) {
          this.createInfiniteClones();
          this.positionIndex = 1;
          this.setTrackPosition(true);
        } else {
          this.positionIndex = 0;
        }

        if (this.effect === 'fade') {
          this.track.style.transitionDuration =
            `${this.transitionSpeed}ms`;
        }

        if (this.previousButton) {
          this.previousButton.addEventListener('click', () => {
            this.previous(true);
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.next(true);
          });
        }

        this.dotButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const index = Number(button.dataset.sliderDot);
            this.goTo(index, true);
          });
        });

        if (this.pauseOnHover) {
          this.addEventListener('mouseenter', () => {
            this.pauseAutoplay();
          });

          this.addEventListener('mouseleave', () => {
            this.startAutoplay();
          });
        }

        this.addEventListener('focusin', () => {
          this.pauseAutoplay();
        });

        this.addEventListener('focusout', (event) => {
          if (!this.contains(event.relatedTarget)) {
            this.startAutoplay();
          }
        });

        if (this.keyboardEnabled) {
          this.addEventListener('keydown', this.handleKeydown);
        }

        if (this.touchSwipeEnabled || this.mouseDragEnabled) {
          this.viewport.addEventListener(
            'pointerdown',
            this.handlePointerDown
          );

          this.viewport.addEventListener(
            'pointermove',
            this.handlePointerMove
          );

          this.viewport.addEventListener(
            'pointerup',
            this.handlePointerUp
          );

          this.viewport.addEventListener(
            'pointercancel',
            this.handlePointerCancel
          );

          this.addEventListener(
            'click',
            this.handleClickCapture,
            true
          );
        }

        this.track.addEventListener(
          'transitionend',
          this.handleTransitionEnd
        );

        document.addEventListener(
          'visibilitychange',
          this.handleVisibilityChange
        );

        this.addEventListener(
          'shopify:block:select',
          this.handleBlockSelect
        );

