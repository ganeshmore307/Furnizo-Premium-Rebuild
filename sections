        checkoutLink.className = 'premium-header__cart-primary-button';
        checkoutLink.href = this.cartDrawerConfig.dataset.checkoutUrl || '/checkout';
        checkoutLink.textContent = this.cartDrawerConfig.dataset.checkoutLabel || 'Checkout';
        footerActions.append(cartLink, checkoutLink);
        footer.append(subtotal, footerActions);
