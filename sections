        this.cartDrawerShell = this.querySelector('[data-cart-drawer-shell]');
        this.cartDrawer = this.querySelector('[data-cart-drawer]');
        this.cartDrawerBody = this.querySelector('[data-cart-drawer-body]');
        this.cartDrawerCount = this.querySelector('[data-cart-drawer-count]');
        this.cartDrawerConfig = this.querySelector('[data-cart-drawer-config]');
        this.cartDrawerCloseButtons = Array.from(this.querySelectorAll('[data-cart-drawer-close]'));
        this.activeCartTrigger = null;

        this.cartLinks.forEach((link) => {
