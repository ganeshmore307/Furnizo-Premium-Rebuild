        const normalizedIndex = Math.max(
          0,
          Math.min(index, this.slideCount - 1)
        );

        this.currentIndex = normalizedIndex;

        if (this.effect === 'slide') {
          if (this.infinite) {
            this.positionIndex = normalizedIndex + 1;
          } else {
            this.positionIndex = normalizedIndex;
          }

          this.setTrackPosition(immediate);
        }

        this.render();

        if (userInitiated) {
          this.restartAutoplay();
        }
      }

      next(userInitiated = false) {
        if (this.slideCount <= 1) return;

        if (this.effect === 'slide' && this.infinite) {
          if (this.currentIndex === this.slideCount - 1) {
            this.currentIndex = 0;
            this.positionIndex = this.slideCount + 1;
          } else {
            this.currentIndex += 1;
            this.positionIndex += 1;
          }

          this.setTrackPosition(false);
          this.render();
        } else if (this.currentIndex < this.slideCount - 1) {
          this.goTo(this.currentIndex + 1);
        } else if (this.infinite) {
          this.goTo(0);
        } else {
          this.pauseAutoplay();
        }

        if (userInitiated) {
          this.restartAutoplay();
        }
      }

      previous(userInitiated = false) {
        if (this.slideCount <= 1) return;

        if (this.effect === 'slide' && this.infinite) {
          if (this.currentIndex === 0) {
            this.currentIndex = this.slideCount - 1;
            this.positionIndex = 0;
          } else {
            this.currentIndex -= 1;
            this.positionIndex -= 1;
          }

          this.setTrackPosition(false);
          this.render();
        } else if (this.currentIndex > 0) {
          this.goTo(this.currentIndex - 1);
        } else if (this.infinite) {
          this.goTo(this.slideCount - 1);
        }

        if (userInitiated) {
          this.restartAutoplay();
        }
      }

      handleTransitionEnd(event) {
        if (
          event.target !== this.track ||
          this.effect !== 'slide' ||
          !this.infinite
        ) {
          return;
        }

        if (this.positionIndex === this.slideCount + 1) {
          this.positionIndex = 1;
          this.setTrackPosition(true);
        } else if (this.positionIndex === 0) {
          this.positionIndex = this.slideCount;
          this.setTrackPosition(true);
        }
      }

      render() {
        this.originalSlides.forEach((slide, index) => {
          const isActive = index === this.currentIndex;
          const links = slide.querySelectorAll('[data-slide-link]');

          slide.classList.toggle('is-active', isActive);
          slide.setAttribute(
            'aria-hidden',
            isActive ? 'false' : 'true'
          );

          links.forEach((link) => {
            link.setAttribute('tabindex', isActive ? '0' : '-1');
          });
        });

        this.dotButtons.forEach((dot, index) => {
          const isActive = index === this.currentIndex;

          dot.classList.toggle('is-active', isActive);
          dot.setAttribute(
            'aria-selected',
            isActive ? 'true' : 'false'
          );
        });

        if (this.previousButton && !this.infinite) {
          this.previousButton.disabled = this.currentIndex === 0;
          this.previousButton.style.opacity =
            this.currentIndex === 0 ? '0.45' : '1';
        }

        if (this.nextButton && !this.infinite) {
          this.nextButton.disabled =
            this.currentIndex === this.slideCount - 1;
          this.nextButton.style.opacity =
            this.currentIndex === this.slideCount - 1
              ? '0.45'
              : '1';
        }

        if (this.liveRegion) {
          this.liveRegion.textContent =
            `Slide ${this.currentIndex + 1} of ${this.slideCount}`;
        }

        this.updateAdaptiveHeight();
      }

      updateAdaptiveHeight() {
        if (!this.adaptiveHeight || !this.viewport) return;

        const activeSlide =
          this.originalSlides[this.currentIndex];

        if (!activeSlide) return;

        const image = activeSlide.querySelector('img');

        if (!image) return;

        const applyHeight = () => {
          if (!image.naturalWidth || !image.naturalHeight) return;

          const viewportWidth =
            this.viewport.getBoundingClientRect().width;

          if (!viewportWidth) return;

          const ratio =
            image.naturalHeight / image.naturalWidth;

          const minimumHeight =
            window.innerWidth <= 749
              ? Number(this.dataset.mobileMinHeight) || 0
              : Number(this.dataset.desktopMinHeight) || 0;

          const calculatedHeight = Math.max(
            viewportWidth * ratio,
            minimumHeight
          );

          this.viewport.style.height =
            `${Math.round(calculatedHeight)}px`;
        };

        if (image.complete) {
          applyHeight();
        } else {
          image.addEventListener('load', applyHeight, {
            once: true
          });
        }
      }

      handleKeydown(event) {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          this.previous(true);
        }

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          this.next(true);
        }
      }

      handlePointerDown(event) {
        if (
          event.pointerType === 'mouse' &&
          !this.mouseDragEnabled
        ) {
          return;
        }

        if (
          event.pointerType !== 'mouse' &&
          !this.touchSwipeEnabled
        ) {
          return;
        }

        if (event.button !== undefined && event.button !== 0) {
          return;
        }

        this.isPointerActive = true;
        this.hasDragged = false;
        this.pointerStartX = event.clientX;
        this.pointerDeltaX = 0;

        this.pauseAutoplay();
        this.classList.add('is-dragging');

        if (this.viewport.setPointerCapture) {
          try {
            this.viewport.setPointerCapture(event.pointerId);
          } catch (error) {}
        }
      }

      handlePointerMove(event) {
        if (!this.isPointerActive) return;

        this.pointerDeltaX =
          event.clientX - this.pointerStartX;

        if (Math.abs(this.pointerDeltaX) > 6) {
          this.hasDragged = true;
        }

        if (
          this.effect === 'slide' &&
          this.hasDragged
        ) {
          event.preventDefault();
          this.track.style.transition = 'none';

          this.track.style.transform =
            `translate3d(calc(-${this.positionIndex * 100}% + ` +
            `${this.pointerDeltaX}px), 0, 0)`;
        }
      }

      handlePointerUp(event) {
        if (!this.isPointerActive) return;

        const dragDistance = this.pointerDeltaX;
        const swipeThreshold = Math.min(
          80,
          Math.max(40, this.viewport.offsetWidth * 0.08)
        );

        this.isPointerActive = false;
        this.classList.remove('is-dragging');

        if (this.viewport.releasePointerCapture) {
          try {
            this.viewport.releasePointerCapture(event.pointerId);
          } catch (error) {}
        }

        if (Math.abs(dragDistance) >= swipeThreshold) {
          this.suppressClick = true;

          if (dragDistance > 0) {
            this.previous(true);
          } else {
            this.next(true);
          }
        } else {
          if (this.effect === 'slide') {
            this.setTrackPosition(false);
          }

          if (this.hasDragged) {
            this.suppressClick = true;
          }

          this.startAutoplay();
        }

        this.pointerDeltaX = 0;
        this.hasDragged = false;
      }

      handlePointerCancel() {
        if (!this.isPointerActive) return;

        this.isPointerActive = false;
        this.pointerDeltaX = 0;
        this.hasDragged = false;
        this.classList.remove('is-dragging');

        if (this.effect === 'slide') {
          this.setTrackPosition(false);
        }

        this.startAutoplay();
      }

      handleClickCapture(event) {
        if (!this.suppressClick) return;

        event.preventDefault();
        event.stopPropagation();
        this.suppressClick = false;
      }

      handleVisibilityChange() {
        if (document.hidden) {
          this.pauseAutoplay();
        } else {
          this.startAutoplay();
        }
      }

      handleResize() {
        this.updateAdaptiveHeight();
      }

      handleBlockSelect(event) {
        const selectedSlide = event.target.closest(
          '[data-slide-index]'
        );

        if (!selectedSlide) return;

        const selectedIndex = Number(
          selectedSlide.dataset.slideIndex
        );

        if (!Number.isNaN(selectedIndex)) {
          this.pauseAutoplay();
          this.goTo(selectedIndex, false, true);
        }
      }

      startAutoplay() {
        if (
          !this.autoplayEnabled ||
          this.slideCount <= 1 ||
          document.hidden
        ) {
          return;
        }

        this.pauseAutoplay();

        this.autoplayTimer = window.setInterval(() => {
          this.next(false);
        }, this.autoplaySpeed);
      }

      pauseAutoplay() {
        if (!this.autoplayTimer) return;

        window.clearInterval(this.autoplayTimer);
        this.autoplayTimer = null;
      }

      restartAutoplay() {
        this.pauseAutoplay();
        this.startAutoplay();
      }
    }

    customElements.define(
      'luxury-hero-banner',
      LuxuryHeroBanner
    );
  }
</script>

