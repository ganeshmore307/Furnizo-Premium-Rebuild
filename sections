<script>
  (() => {
    class PremiumPredictiveSearch {
      constructor(form, signal) {
        this.form = form;
        this.input = form.querySelector('.premium-header__search-input');
        this.results = form.querySelector('[data-predictive-results]');
        this.endpoint = form.dataset.predictiveUrl;
        this.signal = signal;
        this.timer = null;
        this.requestController = null;
        this.query = '';

        if (!this.input || !this.results || !this.endpoint) return;

        this.input.addEventListener('input', () => this.handleInput(), { signal });
        this.input.addEventListener('keydown', (event) => this.handleKeydown(event), { signal });
        this.input.addEventListener('focus', () => {
          if (this.query.length > 1 && this.results.childElementCount) this.open();
        }, { signal });
      }

      handleInput() {
        const value = this.input.value.trim();
        window.clearTimeout(this.timer);
        this.query = value;

        if (value.length < 2) {
          this.close();
          return;
        }

        this.renderStatus('Searching…');
        this.open();
        this.timer = window.setTimeout(() => this.fetchResults(value), 180);
      }

      async fetchResults(query) {
        if (this.requestController) this.requestController.abort();
        this.requestController = new AbortController();

        try {
          const url = new URL(this.endpoint, window.location.origin);
          url.searchParams.set('q', query);
          url.searchParams.set('resources[type]', 'product,collection,page,article');
          url.searchParams.set('resources[limit]', '6');
          url.searchParams.set('resources[options][unavailable_products]', 'hide');
          url.searchParams.set('resources[options][fields]', 'title,product_type,variants.title,tag,body');

          const response = await fetch(url.toString(), {
            headers: { Accept: 'application/json' },
            signal: this.requestController.signal
          });

          if (!response.ok) throw new Error('Predictive search request failed');
          const payload = await response.json();
          if (query !== this.query) return;
          this.renderResults(payload.resources && payload.resources.results ? payload.resources.results : {}, query);
        } catch (error) {
          if (error.name !== 'AbortError') this.close();
        }
      }

      renderStatus(message) {
        const status = document.createElement('div');
        status.className = 'premium-header__search-status';
        status.setAttribute('role', 'status');
        status.textContent = message;
        this.results.replaceChildren(status);
      }

      renderResults(data, query) {
        const fragment = document.createDocumentFragment();
        const groups = [
          ['products', 'Products'],
          ['collections', 'Collections'],
          ['pages', 'Pages'],
          ['articles', 'Articles']
        ];
        let remaining = 8;
        let rendered = 0;

        groups.forEach(([key, label]) => {
          const items = Array.isArray(data[key]) ? data[key].slice(0, remaining) : [];
          if (!items.length || remaining < 1) return;

          const group = document.createElement('section');
          group.className = 'premium-header__result-group';

          const heading = document.createElement('h3');
          heading.className = 'premium-header__result-heading';
          heading.textContent = label;
          group.appendChild(heading);

          items.forEach((item) => {
            const link = document.createElement('a');
            link.className = 'premium-header__result-link';
            link.href = item.url || '#';

            const imageSource = item.featured_image && item.featured_image.url
              ? item.featured_image.url
              : (typeof item.featured_image === 'string' ? item.featured_image : '');

            if (imageSource) {
              const image = document.createElement('img');
              image.className = 'premium-header__result-image';
              image.src = imageSource;
              image.alt = '';
              image.loading = 'lazy';
              image.width = 44;
              image.height = 44;
