<style>
  #shopify-section-{{ section.id }} {
    --lhb-background: {{ section.settings.section_background }};
    --lhb-container-width: {{ section.settings.container_width }}px;

    --lhb-desktop-height: {{ section.settings.desktop_height }}px;
    --lhb-laptop-height: {{ section.settings.laptop_height }}px;
    --lhb-tablet-height: {{ section.settings.tablet_height }}px;
    --lhb-mobile-height: {{ section.settings.mobile_height }}px;

    --lhb-desktop-min-height: {{ section.settings.desktop_min_height }}px;
    --lhb-mobile-min-height: {{ section.settings.mobile_min_height }}px;

    --lhb-radius: {{ section.settings.image_radius }}px;
    --lhb-transition-speed: {{ section.settings.transition_speed }}ms;

    --lhb-arrow-size: {{ section.settings.arrow_size }}px;
    --lhb-arrow-color: {{ section.settings.arrow_color }};
    --lhb-arrow-background: {{ section.settings.arrow_background }};
    --lhb-arrow-hover-color: {{ section.settings.arrow_hover_color }};
    --lhb-arrow-hover-background: {{ section.settings.arrow_hover_background }};

    --lhb-dot-size: {{ section.settings.dot_size }}px;
    --lhb-dot-color: {{ section.settings.dot_color }};
    --lhb-dot-active-color: {{ section.settings.dot_active_color }};

    width: 100%;
    margin-top: {{ section.settings.desktop_margin_top }}px;
    margin-bottom: {{ section.settings.desktop_margin_bottom }}px;
    padding:
      {{ section.settings.desktop_padding_top }}px
      {{ section.settings.desktop_padding_right }}px
      {{ section.settings.desktop_padding_bottom }}px
      {{ section.settings.desktop_padding_left }}px;
    overflow: clip;
    background: var(--lhb-background);
  }

  #shopify-section-{{ section.id }} * {
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .luxury-hero {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .luxury-hero--boxed {
    width: min(100%, var(--lhb-container-width));
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .luxury-hero__slider {
    position: relative;
    width: 100%;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .luxury-hero__viewport {
    position: relative;
    width: 100%;
    height: var(--lhb-desktop-height);
    min-height: var(--lhb-desktop-min-height);
    overflow: hidden;
    border-radius: var(--lhb-radius);
    background: var(--lhb-background);
    touch-action: pan-y;
    user-select: none;
    -webkit-user-select: none;
  }

  #shopify-section-{{ section.id }} .luxury-hero--shadow .luxury-hero__viewport {
    box-shadow: 0 18px 45px rgba(30, 20, 16, 0.18);
  }

  #shopify-section-{{ section.id }} .luxury-hero--adaptive .luxury-hero__viewport {
    height: auto;
    transition: height var(--lhb-transition-speed) ease;
  }

  #shopify-section-{{ section.id }} .luxury-hero__track {
    width: 100%;
    height: 100%;
    display: flex;
    margin: 0;
    padding: 0;
    transform: translate3d(0, 0, 0);
    transition:
      transform var(--lhb-transition-speed) cubic-bezier(0.22, 0.61, 0.36, 1);
    will-change: transform;
  }

  #shopify-section-{{ section.id }} .luxury-hero__slide {
    position: relative;
    flex: 0 0 100%;
    width: 100%;
    min-width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .luxury-hero__media-link,
  #shopify-section-{{ section.id }} .luxury-hero__media {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .luxury-hero__picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .luxury-hero__image {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    object-fit: {{ section.settings.image_fit }};
    object-position: var(--lhb-desktop-position, center center);
    pointer-events: none;
    -webkit-user-drag: none;
  }

  #shopify-section-{{ section.id }} .luxury-hero--natural .luxury-hero__image,
  #shopify-section-{{ section.id }} .luxury-hero--adaptive .luxury-hero__image {
    height: auto;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .luxury-hero__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    background: #eeeae5;
  }

  #shopify-section-{{ section.id }} .luxury-hero--fade .luxury-hero__track {
    position: relative;
    display: block;
    transform: none !important;
  }

  #shopify-section-{{ section.id }} .luxury-hero--fade .luxury-hero__slide {
    position: absolute;
    inset: 0;
    z-index: 0;
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
