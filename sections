{% endstyle %}

<premium-header
  id="PremiumHeader-{{ section.id }}"
  class="premium-header premium-header--{{ section.settings.layout_mode }}{% if section.settings.transparent_header %} is-transparent{% endif %}{% if section.settings.blur_background %} has-blur{% endif %}"
  data-section-id="{{ section.id }}"
  data-announcement-rotation="{{ section.settings.announcement_rotation }}"
  data-cart-url="{{ routes.cart_url }}.js"
  data-cart-change-url="{{ routes.cart_change_url }}.js"
  data-cart-label="{{ cart_label | escape }}"
  data-currency="{{ cart.currency.iso_code | default: localization.country.currency.iso_code }}"
  data-locale="{{ request.locale.iso_code }}"
>
  {% if section.settings.announcement_enable and announcement_count > 0 %}
    <div class="premium-header__announcement" data-announcement-bar aria-label="Store announcements">
      <div class="premium-header__announcement-track" aria-live="polite" aria-atomic="true">
        {% assign announcement_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'announcement' %}
            <div
              class="premium-header__announcement-item{% if announcement_index == 0 %} is-active{% endif %}"
              data-announcement-item
              data-announcement-index="{{ announcement_index }}"
              style="--announcement-background: {{ block.settings.background_color }}; --announcement-color: {{ block.settings.text_color }}; --announcement-size-desktop: {{ block.settings.font_size_desktop }}px; --announcement-size-mobile: {{ block.settings.font_size_mobile }}px;"
              {% unless announcement_index == 0 %}aria-hidden="true"{% endunless %}
              {{ block.shopify_attributes }}
            >
              {% if block.settings.link != blank %}
                <a class="premium-header__announcement-link" href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
              {% else %}
                <span class="premium-header__announcement-text">{{ block.settings.text | escape }}</span>
              {% endif %}
            </div>
            {% assign announcement_index = announcement_index | plus: 1 %}
          {% endif %}
        {% endfor %}
      </div>
      {% if announcement_count > 1 %}
        <button class="premium-header__announcement-arrow premium-header__announcement-arrow--previous" type="button" aria-label="Previous announcement" data-announcement-previous>
          <svg aria-hidden="true" viewBox="0 0 12 20"><path d="m9.5 2-8 8 8 8"></path></svg>
        </button>
        <button class="premium-header__announcement-arrow premium-header__announcement-arrow--next" type="button" aria-label="Next announcement" data-announcement-next>
          <svg aria-hidden="true" viewBox="0 0 12 20"><path d="m2.5 2 8 8-8 8"></path></svg>
        </button>
      {% endif %}
    </div>
  {% endif %}

  <div class="premium-header__chrome">
    <div class="premium-header__surface">
      <div class="premium-header__container">
        <div class="premium-header__main{% unless section.settings.search_enable %} premium-header__main--no-search{% endunless %}">
          <a class="premium-header__brand premium-header__brand--{{ section.settings.logo_position }}" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }} home">
            {% if section.settings.logo != blank %}
              {{ section.settings.logo | image_url: width: 600 | image_tag:
                class: 'premium-header__logo-image',
                loading: 'lazy',
                widths: '120, 180, 240, 360, 480, 600',
                sizes: '(min-width: 990px) var(--ph-logo-width-desktop), var(--ph-logo-width-mobile)',
                alt: desktop_logo_alt
              }}
            {% else %}
              <span class="premium-header__brand-text">{{ shop.name | escape }}</span>
            {% endif %}
          </a>

          {% if section.settings.search_enable %}
            <div class="premium-header__search-wrap">
              <form
                class="premium-header__search-form"
                action="{{ routes.search_url }}"
                method="get"
                role="search"
                data-predictive-search
                data-predictive-url="{{ routes.predictive_search_url }}.json"
              >
                <div class="premium-header__search-field">
                  <label class="premium-header__visually-hidden" for="PremiumHeaderSearch-{{ section.id }}">Search</label>
                  <input
                    id="PremiumHeaderSearch-{{ section.id }}"
                    class="premium-header__search-input"
                    type="search"
                    name="q"
                    value="{{ search.terms | escape }}"
                    placeholder="{{ section.settings.search_placeholder | escape }}"
                    role="combobox"
                    aria-expanded="false"
                    aria-controls="PremiumHeaderResults-{{ section.id }}"
                    aria-autocomplete="list"
                    autocomplete="off"
                    autocorrect="off"
                    autocapitalize="off"
                    spellcheck="false"
                  >
                  <input type="hidden" name="options[prefix]" value="last">
                  <button class="premium-header__search-button" type="submit" aria-label="Search">
                    <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
                      <circle cx="10.8" cy="10.8" r="6.8" stroke="currentColor" stroke-width="1.8"></circle>
                      <path d="m16 16 4 4" stroke="currentColor" stroke-linecap="round" stroke-width="1.8"></path>
                    </svg>
                  </button>
                </div>
                <div id="PremiumHeaderResults-{{ section.id }}" class="premium-header__predictive-results" data-predictive-results hidden></div>
              </form>
            </div>
          {% endif %}

          <div class="premium-header__actions" aria-label="Customer actions"{% if action_block != blank %} {{ action_block.shopify_attributes }}{% endif %}>
            {% if section.settings.account_enable %}
              <a class="premium-header__icon-link" href="{{ account_url }}" aria-label="{{ account_label | escape }}">
                <svg class="premium-header__icon" aria-hidden="true" viewBox="0 0 24 24">
                  <circle cx="12" cy="7.25" r="3.75"></circle>
                  <path d="M4.5 20c.55-4.12 3.17-6.4 7.5-6.4s6.95 2.28 7.5 6.4"></path>
                </svg>
                {% if show_action_labels %}<span class="premium-header__icon-label">{{ account_label | escape }}</span>{% endif %}
              </a>
            {% endif %}

            {% if section.settings.wishlist_enable %}
              <a
                class="premium-header__icon-link wishlist-link swym-wishlist wishlist-hero-header-icon"
                href="{{ wishlist_url }}"
                aria-label="{{ wishlist_label | escape }}"
                data-wishlist-link
              >
                <svg class="premium-header__icon" aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M20.84 5.61a5.5 5.5 0 0 0-7.78 0L12 6.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 22.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78Z"></path>
                </svg>
                {% if show_action_labels %}<span class="premium-header__icon-label">{{ wishlist_label | escape }}</span>{% endif %}
              </a>
            {% endif %}

            {% if section.settings.cart_enable %}
              <a class="premium-header__icon-link" href="{{ routes.cart_url }}" aria-label="{{ cart_label | escape }} with {{ cart.item_count }} items" data-cart-link>
                <svg class="premium-header__icon" aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M5.5 8.5h13l-.75 12h-11.5l-.75-12Z"></path>
                  <path d="M9 9V6a3 3 0 0 1 6 0v3"></path>
                </svg>
                <span
                  class="premium-header__cart-badge premium-header__cart-badge--{{ section.settings.badge_position }}"
                  data-cart-count
                  {% if cart.item_count == 0 %}hidden{% endif %}
                >{{ cart.item_count }}</span>
                {% if show_action_labels %}<span class="premium-header__icon-label">{{ cart_label | escape }}</span>{% endif %}
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {% if section.settings.menu_enable and section.settings.menu != blank %}
      <nav class="premium-header__navigation" aria-label="Primary navigation">
        <div class="premium-header__container">
          <ul class="premium-header__menu" role="list">
            {% for link in section.settings.menu.links %}
              {% assign mega_block = blank %}
              {% assign link_handle = link.title | handleize %}
              {% for block in section.blocks %}
                {% if block.type == 'mega_menu' %}
                  {% assign trigger_handle = block.settings.trigger | handleize %}
                  {% if trigger_handle == link_handle and block.settings.trigger != blank %}
                    {% assign mega_block = block %}
                    {% break %}
                  {% endif %}
                {% endif %}
              {% endfor %}

              <li class="premium-header__menu-item">
                <a
                  class="premium-header__menu-link{% if link.current or link.child_active %} is-active{% endif %}"
                  href="{{ link.url }}"
                  {% if link.current %}aria-current="page"{% endif %}
                  {% if link.links != blank or mega_block != blank %}aria-haspopup="true"{% endif %}
                >
                  <span>{{ link.title | escape }}</span>
                  {% if link.links != blank or mega_block != blank %}
                    <svg class="premium-header__menu-chevron" aria-hidden="true" viewBox="0 0 10 6">
                      <path d="m1 1 4 4 4-4"></path>
