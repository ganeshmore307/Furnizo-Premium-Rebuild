<style>
  .faz-look { padding: 0; }
  .faz-look-stage { position: relative; max-width: 100%; overflow: hidden; }
  .faz-look-img { width: 100%; display: block; }
  .faz-look-caption { position: absolute; left: 40px; bottom: 40px; color: #fff; max-width: 320px; z-index: 3; }
  .faz-look-heading { font-family: Georgia, 'Playfair Display', serif; font-size: 30px; margin: 0 0 6px; }
  .faz-look-sub { font-size: 13px; opacity: .9; margin: 0 0 14px; }
  .faz-look-cta { display:inline-block; text-decoration: underline; font-size: 12px; letter-spacing: 1px; text-transform: uppercase; color: #fff; }
  .faz-hotspot { position:absolute; width: 26px; height: 26px; border-radius: 50%; background: rgba(255,255,255,.35); border: 2px solid #fff; cursor:pointer; transform: translate(-50%,-50%); padding:0; z-index: 4; }
  .faz-hotspot-dot { display:block; width:8px; height:8px; margin:7px auto; border-radius:50%; background:#fff; }
  .faz-hotspot::before { content:''; position:absolute; inset:-6px; border-radius:50%; border:1px solid rgba(255,255,255,.6); animation: faz-pulse 2.2s ease-out infinite; }
  @keyframes faz-pulse { 0% { transform: scale(1); opacity: .8; } 100% { transform: scale(1.7); opacity: 0; } }
  .faz-hotspot-card { position:absolute; transform: translate(-50%, 12px); background:#fff; border-radius: 4px; box-shadow: 0 10px 30px rgba(0,0,0,.18); width: 220px; opacity:0; visibility:hidden; transition: opacity .2s ease, transform .2s ease; z-index: 5; }
  .faz-hotspot-card.faz-open { opacity:1; visibility:visible; transform: translate(-50%, 22px); }
  .faz-hc-inner { display:flex; gap:10px; align-items:center; padding: 10px; text-decoration:none; color:#2b2420; }
  .faz-hc-inner img { width: 56px; height: 56px; object-fit: cover; border-radius: 2px; flex-shrink:0; }
  .faz-hc-info { display:flex; flex-direction:column; gap:2px; }
  .faz-hc-title { font-size: 12px; font-weight: 600; line-height:1.3; }
  .faz-hc-price { font-size: 12px; color: #6b1f2a; }
  @media (prefers-reduced-motion: reduce) { .faz-hotspot::before { animation: none; } .faz-hotspot-card { transition: none; } }
  @media (max-width: 749px) { .faz-look-caption { left: 20px; bottom: 20px; max-width: 220px; } .faz-look-heading { font-size: 22px; } .faz-hotspot-card { width: 180px; } }
</style>

<script>
  (function(){
    var section = document.currentScript.closest('.faz-look');
    if (!section) return;
    var buttons = section.querySelectorAll('.faz-hotspot');
    buttons.forEach(function(btn){
      btn.addEventListener('click', function(e){
        e.stopPropagation();
        var id = btn.getAttribute('data-hotspot-id');
        var card = section.querySelector('[data-hotspot-card="' + id + '"]');
        section.querySelectorAll('.faz-hotspot-card').forEach(function(c){ if (c !== card) c.classList.remove('faz-open'); });
        if (card) card.classList.toggle('faz-open');
      });
    });
    document.addEventListener('click', function(){ section.querySelectorAll('.faz-hotspot-card').forEach(function(c){ c.classList.remove('faz-open'); }); });
  })();
</script>

