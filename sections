                                <li class="premium-header__mega-benefit">
                                  <span class="premium-header__mega-benefit-icon" aria-hidden="true">
                                    {% case benefit_icon %}
                                      {% when 'cod' %}
                                        <svg viewBox="0 0 32 32"><rect x="4" y="6" width="24" height="18" rx="3"></rect><path d="M10 24v3m12-3v3"></path><text x="16" y="18" text-anchor="middle" font-size="7" font-weight="700" fill="currentColor" stroke="none">COD</text></svg>
                                      {% when 'box' %}
                                        <svg viewBox="0 0 32 32"><path d="m5 10 11-6 11 6v13l-11 6-11-6V10Z"></path><path d="m5 10 11 6 11-6M16 16v13M10.5 7 22 13"></path></svg>
                                      {% when 'truck' %}
                                        <svg viewBox="0 0 32 32"><path d="M3 8h17v15H3zM20 13h5l4 5v5h-9z"></path><circle cx="9" cy="25" r="2.5"></circle><circle cx="24" cy="25" r="2.5"></circle><path d="M20 18h9"></path></svg>
                                      {% when 'chair' %}
                                        <svg viewBox="0 0 32 32"><path d="M9 15V8a7 7 0 0 1 14 0v7M7 15h18v7H7zM9 22v6m14-6v6M12 15v-4h8v4"></path></svg>
                                      {% when 'quality' %}
                                        <svg viewBox="0 0 32 32"><path d="m16 3 3 2 4-.2 1.7 3.6 3.5 1.9-.6 4 1.9 3-2.7 3 .2 4-3.8 1.5-2.1 3.4-3.9-.9-3.3 2.3-3.3-2.3-3.9.9-2.1-3.4L2 24l.2-4-2.7-3 1.9-3-.6-4 3.5-1.9L6 4.8l4 .2 3-2Z"></path><path d="m10.5 16 3.5 3.5 7.5-8"></path></svg>
                                      {% else %}
                                        <svg viewBox="0 0 32 32"><path d="M16 3v5M7 7l3.5 3.5M3 16h5m-1 9 3.5-3.5M25 7l-3.5 3.5M29 16h-5m1 9-3.5-3.5"></path><circle cx="16" cy="16" r="7"></circle><path d="m12.5 16 2.3 2.3 4.8-5"></path></svg>
                                    {% endcase %}
                                  </span>
                                  <span>{{ benefit_text | escape }}</span>
                                </li>
                              {% endif %}
                            {% endfor %}
                          </ul>
                        </aside>
                      {% elsif mega_panel_style == 'promo' %}
                        {% if mega_block.settings.promo_image != blank or mega_block.settings.heading != blank or mega_block.settings.text != blank %}
