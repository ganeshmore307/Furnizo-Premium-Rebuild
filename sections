<section
  id="{{ section_id }}"
  class="sc-section{% if section.settings.full_width %} sc-full{% endif %}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
  data-pause-hover="{{ section.settings.pause_hover }}"
  data-infinite="{{ section.settings.infinite_loop }}"
  aria-label="{{ section.settings.heading | default: 'Shop by category' | escape }}"
>
  <div class="sc-container">
    <div class="sc-header">
      {%- if section.settings.show_heading and section.settings.heading != blank -%}
        <h2 class="sc-heading">
          {{ section.settings.heading | escape }}
        </h2>
      {%- endif -%}

      {%- if section.settings.show_navigation -%}
        <div
          class="sc-navigation"
          aria-label="Category slider navigation"
        >
          <button
            type="button"
            class="sc-nav"
            data-sc-prev
            aria-label="Previous categories"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M15 5l-7 7 7 7"></path>
            </svg>
          </button>

          <button
            type="button"
            class="sc-nav"
            data-sc-next
            aria-label="Next categories"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    <div
      class="sc-track"
      data-sc-track
      role="list"
      tabindex="0"
      aria-label="{{ section.settings.heading | default: 'Categories' | escape }}"
    >
      {%- for block in section.blocks -%}
        {%- liquid
          assign card_collection = block.settings.collection
          assign card_image = block.settings.desktop_image

          if card_image == blank and card_collection != blank
            assign card_image = card_collection.featured_image
          endif

          assign card_title = block.settings.custom_title

          if card_title == blank and card_collection != blank
            assign card_title = card_collection.title
          endif

          if card_title == blank
            assign card_title = 'Category'
          endif

          assign card_link = block.settings.custom_link

          if card_link == blank and card_collection != blank
            assign card_link = card_collection.url
          endif

          if card_link == blank
            assign card_link = routes.all_products_collection_url
          endif

          assign image_alt = block.settings.alt_text

          if image_alt == blank and card_image != blank
            assign image_alt = card_image.alt
          endif

          if image_alt == blank
            assign image_alt = card_title
          endif
        -%}

        <a
          class="sc-card"
          href="{{ card_link }}"
          role="listitem"
          aria-label="{{ card_title | escape }}"
          {% if block.settings.open_new_tab %}
            target="_blank"
            rel="noopener noreferrer"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="sc-media">
            {%- if card_image != blank -%}
              <picture>
                {%- if block.settings.mobile_image != blank -%}
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {{ block.settings.mobile_image | image_url: width: 320 }} 320w,
                      {{ block.settings.mobile_image | image_url: width: 480 }} 480w,
                      {{ block.settings.mobile_image | image_url: width: 640 }} 640w,
                      {{ block.settings.mobile_image | image_url: width: 800 }} 800w
                    "
                    sizes="82vw"
                  >
                {%- endif -%}

                {{-
                  card_image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '240, 320, 480, 640, 800, 1000, 1200',
                    sizes: '(min-width: 1400px) 16vw, (min-width: 990px) 20vw, (min-width: 750px) 33vw, 82vw',
                    loading: image_loading,
                    class: 'sc-image',
                    alt: image_alt,
                    decoding: 'async'
                -}}
              </picture>
            {%- else -%}
              {{
                'collection-1'
                | placeholder_svg_tag: 'sc-placeholder'
              }}
            {%- endif -%}
          </div>

          <span class="sc-title-row">
            <span>{{ card_title | escape }}</span>

            <span class="sc-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M5 12h13M13 7l5 5-5 5"></path>
              </svg>
            </span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.getElementById('{{ section_id }}');

    if (!root || root.dataset.ready === 'true') {
      return;
    }

    const track = root.querySelector('[data-sc-track]');

    if (!track) {
      return;
    }

    root.dataset.ready = 'true';

    const previous = root.querySelector('[data-sc-prev]');
    const next = root.querySelector('[data-sc-next]');

    const autoplay = root.dataset.autoplay === 'true';
    const pauseHover = root.dataset.pauseHover === 'true';
    const infinite = root.dataset.infinite === 'true';

    const speed = Math.max(
      1000,
      Number(root.dataset.speed) || 3000
    );

    const reducedMotion = window
      .matchMedia('(prefers-reduced-motion: reduce)')
      .matches;

    const originals = Array.from(
      track.querySelectorAll('.sc-card')
    );

    let firstClone = null;
    let cloneStart = 0;
    let timer = null;
    let pointerDown = false;
    let dragged = false;
    let startX = 0;
    let startScroll = 0;

    if (infinite && originals.length) {
      originals.forEach((card) => {
        const clone = card.cloneNode(true);

        clone.removeAttribute(
          'data-shopify-editor-block'
        );

        clone.dataset.clone = 'true';
        clone.setAttribute('aria-hidden', 'true');
        clone.setAttribute('tabindex', '-1');

        if (!firstClone) {
          firstClone = clone;
        }

        track.appendChild(clone);
      });
    }

    const updateLoopPosition = () => {
      if (!firstClone || !track.firstElementChild) {
        cloneStart = 0;
        return;
      }

      cloneStart =
        firstClone.offsetLeft -
        track.firstElementChild.offsetLeft;
    };

    const getStep = () => {
      const card = track.querySelector(
        '.sc-card:not([data-clone])'
      );

      if (!card) {
        return track.clientWidth;
      }

      const styles = window.getComputedStyle(track);

      const gap =
        parseFloat(
          styles.columnGap || styles.gap
        ) || 0;

      return (
        card.getBoundingClientRect().width +
        gap
      );
    };

    const jumpTo = (left) => {
      const behavior = track.style.scrollBehavior;

      track.style.scrollBehavior = 'auto';
      track.scrollLeft = left;
      track.offsetHeight;
      track.style.scrollBehavior = behavior;
    };

    const move = (direction) => {
      updateLoopPosition();

      if (
        direction < 0 &&
        infinite &&
        track.scrollLeft <= 2 &&
        cloneStart > 0
      ) {
        jumpTo(cloneStart);
      }

      if (
        direction > 0 &&
        !infinite &&
        track.scrollLeft >=
          track.scrollWidth -
          track.clientWidth -
          4
      ) {
        track.scrollTo({
          left: 0,
          behavior: 'smooth'
        });

        return;
      }

      track.scrollBy({
        left: getStep() * direction,
        behavior: 'smooth'
      });
    };

    const stopAutoplay = () => {
      if (!timer) {
        return;
      }

      window.clearInterval(timer);
      timer = null;
    };

    const startAutoplay = () => {
      stopAutoplay();

      if (
        !autoplay ||
        reducedMotion ||
        originals.length < 2
      ) {
        return;
      }

      timer = window.setInterval(
        () => move(1),
        speed
      );
    };

    if (previous) {
      previous.addEventListener(
        'click',
        () => move(-1)
      );
    }

    if (next) {
      next.addEventListener(
        'click',
        () => move(1)
      );
    }

    track.addEventListener(
      'pointerdown',
      (event) => {
        if (
          event.pointerType === 'touch' ||
          event.button !== 0
        ) {
          return;
        }

        stopAutoplay();

        pointerDown = true;
        dragged = false;
        startX = event.clientX;
        startScroll = track.scrollLeft;

        track.classList.add('is-dragging');
        track.setPointerCapture(event.pointerId);
      }
    );

    track.addEventListener(
      'pointermove',
      (event) => {
        if (!pointerDown) {
          return;
        }

        const distance =
          event.clientX - startX;

        if (Math.abs(distance) > 5) {
          dragged = true;
        }

        track.scrollLeft =
          startScroll - distance;

        if (dragged) {
          event.preventDefault();
        }
      }
    );

    const stopDrag = (event) => {
      if (!pointerDown) {
        return;
      }

      pointerDown = false;
      track.classList.remove('is-dragging');

      if (
        track.hasPointerCapture(event.pointerId)
      ) {
        track.releasePointerCapture(
          event.pointerId
        );
      }

      startAutoplay();
    };

    track.addEventListener(
      'pointerup',
      stopDrag
    );

    track.addEventListener(
      'pointercancel',
      stopDrag
    );

    track.addEventListener(
      'click',
      (event) => {
        if (!dragged) {
          return;
        }

        event.preventDefault();
        event.stopPropagation();
        dragged = false;
      },
      true
    );

    let scrollFrame = null;

    track.addEventListener(
      'scroll',
      () => {
        if (
          !infinite ||
          cloneStart <= 0 ||
          scrollFrame
        ) {
          return;
        }

        scrollFrame =
          window.requestAnimationFrame(() => {
            updateLoopPosition();

            if (
              track.scrollLeft >=
              cloneStart - 1
            ) {
              jumpTo(
                track.scrollLeft -
                cloneStart
              );
            }

            scrollFrame = null;
          });
      },
      { passive: true }
    );

    track.addEventListener(
      'keydown',
      (event) => {
        if (
          event.key !== 'ArrowLeft' &&
          event.key !== 'ArrowRight'
        ) {
          return;
        }

        move(
          event.key === 'ArrowRight'
            ? 1
            : -1
        );

        event.preventDefault();
      }
    );

    if (pauseHover) {
      root.addEventListener(
        'mouseenter',
        stopAutoplay
      );

      root.addEventListener(
        'mouseleave',
        startAutoplay
      );

      root.addEventListener(
        'focusin',
        stopAutoplay
      );

      root.addEventListener(
        'focusout',
        startAutoplay
      );
    }

    window.addEventListener(
      'resize',
      updateLoopPosition,
      { passive: true }
    );

    window.requestAnimationFrame(
      updateLoopPosition
    );

    startAutoplay();
  })();
</script>

