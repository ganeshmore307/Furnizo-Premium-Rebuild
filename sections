    letter-spacing: 1px;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .premium-product-slider__quick-view-close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    margin: 0;
    padding: 0;
    color: #302824;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid #ddd5d0;
    border-radius: 50%;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .premium-product-slider__quick-view-close svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.8;
  }

  #shopify-section-{{ section.id }} .premium-product-slider__status {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 240;
    max-width: min(360px, calc(100vw - 40px));
    padding: 13px 18px;
    color: #ffffff;
    background: #2f2825;
    border-radius: 3px;
    box-shadow: 0 12px 30px rgba(20, 12, 10, 0.2);
    font-size: 12px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;
  }

  #shopify-section-{{ section.id }} .premium-product-slider__status.is-visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  #shopify-section-{{ section.id }} .premium-product-slider__visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    margin: -1px !important;
    padding: 0 !important;
    overflow: hidden !important;
    clip: rect(0 0 0 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  {% unless slider_block.settings.desktop_slider %}
    @media screen and (min-width: 990px) {
      #shopify-section-{{ section.id }} .premium-product-slider__track {
        flex-wrap: wrap;
        overflow: visible;
      }

      #shopify-section-{{ section.id }} .premium-product-slider__arrow,
      #shopify-section-{{ section.id }} .premium-product-slider__dots {
        display: none;
      }
    }
  {% endunless %}

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .premium-product-slider {
      margin-block: var(--pps-margin-tablet);
    }

    #shopify-section-{{ section.id }} .premium-product-slider__container {
      padding: var(--pps-padding-tablet);
    }

    #shopify-section-{{ section.id }} .premium-product-slider__heading {
      margin-bottom: 26px;
      font-size: var(--pps-heading-tablet);
    }

    #shopify-section-{{ section.id }} .premium-product-slider__track {
      gap: var(--pps-gap-tablet);
    }

    #shopify-section-{{ section.id }} .premium-product-slider__slide {
      flex-basis: calc((100% - (var(--pps-gap-tablet) * (var(--pps-tablet-view) - 1))) / var(--pps-tablet-view));
    }

    #shopify-section-{{ section.id }} .premium-product-slider__shell--outside .premium-product-slider__arrow--previous {
      left: 8px;
    }

    #shopify-section-{{ section.id }} .premium-product-slider__shell--outside .premium-product-slider__arrow--next {
      right: 8px;
    }
  }

  {% unless slider_block.settings.tablet_slider %}
    @media screen and (min-width: 750px) and (max-width: 989px) {
      #shopify-section-{{ section.id }} .premium-product-slider__track {
        flex-wrap: wrap;
        overflow: visible;
      }

      #shopify-section-{{ section.id }} .premium-product-slider__arrow,
      #shopify-section-{{ section.id }} .premium-product-slider__dots {
        display: none;
      }
    }
  {% endunless %}

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .premium-product-slider {
      margin-block: var(--pps-margin-mobile);
    }

    #shopify-section-{{ section.id }} .premium-product-slider__container {
      padding: var(--pps-padding-mobile);
    }

    #shopify-section-{{ section.id }} .premium-product-slider__heading {
      margin-bottom: 21px;
      font-size: var(--pps-heading-mobile);
    }

    #shopify-section-{{ section.id }} .premium-product-slider__track {
      gap: var(--pps-gap-mobile);
      padding-bottom: 18px;
    }

    #shopify-section-{{ section.id }} .premium-product-slider__slide {
      flex-basis: calc((100% - (var(--pps-gap-mobile) * (var(--pps-mobile-view) - 1))) / var(--pps-mobile-view));
    }

    #shopify-section-{{ section.id }} .premium-product-slider__arrow {
      width: min(var(--pps-arrow-size), 40px);
      height: min(var(--pps-arrow-size), 40px);
    }

    #shopify-section-{{ section.id }} .premium-product-card__media-actions {
      opacity: 1;
      transform: none;
    }

    #shopify-section-{{ section.id }} .premium-product-card__round-action {
      width: 36px;
      height: 36px;
    }

    #shopify-section-{{ section.id }} .premium-product-slider__quick-view {
      grid-template-columns: 1fr;
      max-width: 460px;
    }

    #shopify-section-{{ section.id }} .premium-product-slider__quick-view-image {
      min-height: 280px;
      max-height: 42vh;
    }

    #shopify-section-{{ section.id }} .premium-product-slider__quick-view-content {
      padding: 28px 22px;
    }

    #shopify-section-{{ section.id }} .premium-product-slider__quick-view-title {
      font-size: 22px;
    }
  }

  {% unless slider_block.settings.mobile_slider %}
    @media screen and (max-width: 749px) {
      #shopify-section-{{ section.id }} .premium-product-slider__track {
        flex-wrap: wrap;
        overflow: visible;
      }

      #shopify-section-{{ section.id }} .premium-product-slider__slide {
        flex-basis: 100%;
      }

      #shopify-section-{{ section.id }} .premium-product-slider__arrow,
      #shopify-section-{{ section.id }} .premium-product-slider__dots {
        display: none;
      }
    }
  {% endunless %}

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .premium-product-slider *,
    #shopify-section-{{ section.id }} .premium-product-slider *::before,
    #shopify-section-{{ section.id }} .premium-product-slider *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
{% endstyle %}

<premium-product-slider
  id="PremiumProductSlider-{{ section.id }}"
  class="premium-product-slider premium-product-slider--{{ section.settings.layout_mode }}"
  data-section-id="{{ section.id }}"
  data-infinite="{{ slider_block.settings.infinite_loop }}"
  data-autoplay="{{ slider_block.settings.autoplay }}"
  data-autoplay-speed="{{ slider_block.settings.autoplay_speed | default: 5 }}"
  data-pause-hover="{{ slider_block.settings.pause_hover }}"
  data-mouse-drag="{{ slider_block.settings.mouse_drag }}"
  data-animation="{{ slider_block.settings.animation_style | default: 'slide' }}"
  data-desktop-slider="{{ slider_block.settings.desktop_slider }}"
  data-tablet-slider="{{ slider_block.settings.tablet_slider }}"
  data-mobile-slider="{{ slider_block.settings.mobile_slider }}"
>
  <section aria-labelledby="PremiumProductSliderHeading-{{ section.id }}">
    <div class="premium-product-slider__container">
      {% if section.settings.heading_enable and section.settings.heading != blank %}
        <h2 id="PremiumProductSliderHeading-{{ section.id }}" class="premium-product-slider__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% else %}
        <h2 id="PremiumProductSliderHeading-{{ section.id }}" class="premium-product-slider__visually-hidden">
          Featured products
        </h2>
      {% endif %}

      {% if rendered_count > 0 %}
        <div class="premium-product-slider__shell premium-product-slider__shell--{{ slider_block.settings.arrow_position | default: 'overlay' }}">
          {% if slider_block.settings.dots_enable and slider_block.settings.dots_position == 'top' %}
            <div
              class="premium-product-slider__dots premium-product-slider__dots--top"
              data-slider-dots
              aria-label="Slider pagination"
            ></div>
          {% endif %}

          <div class="premium-product-slider__viewport">
            <div
              class="premium-product-slider__track{% if slider_block.settings.snap_scroll %} is-snap{% endif %}{% if slider_block.settings.hide_scrollbar %} is-scrollbar-hidden{% endif %}"
              data-slider-track
              tabindex="0"
              aria-label="{{ section.settings.heading | default: 'Products' | escape }} carousel"
            >
              {% for product in products_to_show limit: section.settings.max_products %}
                {% liquid
                  assign current_variant = product.selected_or_first_available_variant
                  assign compare_price = product.compare_at_price_max
                  assign sale_price = product.price
                  assign on_sale = false
                  if compare_price > sale_price
                    assign on_sale = true
                  endif
                  assign discount_percent = 0
                  if on_sale
                    assign discount_difference = compare_price | minus: sale_price
                    assign discount_percent = discount_difference | times: 100.0 | divided_by: compare_price | round
                  endif
                  assign second_image = blank
                  if product.images.size > 1
                    assign second_image = product.images[1]
                  endif
                  assign primary_image_class = 'premium-product-card__image premium-product-card__image--primary'
                  if second_image != blank and card_block.settings.show_second_image
                    assign primary_image_class = primary_image_class | append: ' has-secondary'
                  endif
                  assign adaptive_ratio = product.featured_image.aspect_ratio | default: 1
                  assign rating_value = product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value
                  assign rating_max = product.metafields.reviews.rating.value.scale_max | default: 5
                  assign rating_count = product.metafields.reviews.rating_count | default: 0
                  assign rating_percent = 0
                  if rating_value != blank
                    assign rating_percent = rating_value | times: 100.0 | divided_by: rating_max
                  endif
                  assign show_low_inventory = false
                  if card_block.settings.show_inventory and current_variant.inventory_management != blank and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= card_block.settings.inventory_threshold
                    assign show_low_inventory = true
                  endif
                  assign simple_product = false
                  if product.has_only_default_variant
                    assign simple_product = true
                  endif
                %}
                <div class="premium-product-slider__slide" data-slider-slide>
                  <article
                    class="premium-product-card{% if card_block.settings.hover_lift %} has-hover-lift{% endif %}"
                    data-product-card
                    data-product-handle="{{ product.handle | escape }}"
                    data-product-title="{{ product.title | escape }}"
                    data-product-price="{{ product.price | money | escape }}"
                    data-product-url="{{ product.url }}"
                    data-product-image="{% if product.featured_image %}{{ product.featured_image | image_url: width: 900 }}{% endif %}"
                    data-variant-id="{% if simple_product and current_variant.available %}{{ current_variant.id }}{% endif %}"
                  >
                    <div
                      class="premium-product-card__media premium-product-card__media--{{ card_block.settings.image_ratio | default: 'square' }}"
                      style="--pps-adaptive-ratio: {{ adaptive_ratio }};"
                    >
                      <a
                        class="premium-product-card__media-link"
                        href="{{ product.url }}"
                        aria-label="{{ product.title | escape }}"
                      >
                        {% if product.featured_image != blank %}
                          {{
                            product.featured_image
                            | image_url: width: 1000
                            | image_tag:
                              class: primary_image_class,
                              loading: image_loading,
                              widths: '240, 360, 480, 640, 800, 1000',
                              sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 84vw',
                              alt: product.featured_image.alt
                            | default: product.title
                          }}
                          {% if second_image != blank and card_block.settings.show_second_image %}
                            {{
                              second_image
                              | image_url: width: 1000
                              | image_tag:
                                class: 'premium-product-card__image premium-product-card__image--secondary',
                                loading: 'lazy',
                                widths: '240, 360, 480, 640, 800, 1000',
                                sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 84vw',
                                alt: second_image.alt
                              | default: product.title
                            }}
                          {% endif %}
                        {% endif %}
                      </a>

                      <div class="premium-product-card__badges">
                        {% unless product.available %}
                          {% if card_block.settings.show_sold_out -%}
                            <span class="premium-product-card__badge premium-product-card__badge--sold-out"
                              >Sold out</span
                            >
                          {%- endif %}
                        {% elsif on_sale and card_block.settings.show_sale_badge %}
                          <span class="premium-product-card__badge">
                            {%- if card_block.settings.show_discount -%}
                              -{{ discount_percent }}%
                            {%- else -%}
                              Sale
                            {%- endif -%}
                          </span>
                        {% endunless %}
                        {% if show_low_inventory %}
                          <span class="premium-product-card__badge premium-product-card__badge--inventory"
                            >Only {{ current_variant.inventory_quantity }} left</span
                          >
                        {% endif %}
                      </div>

                      {% if card_block.settings.show_wishlist %}
                        <button
                          class="premium-product-card__wishlist wishlist-button swym-button"
                          type="button"
                          aria-label="Add {{ product.title | escape }} to wishlist"
                          aria-pressed="false"
                          data-wishlist-button
                          data-product-handle="{{ product.handle | escape }}"
                          data-product-id="{{ product.id }}"
                        >
                          <svg aria-hidden="true" viewBox="0 0 24 24">
                            <path d="M20.8 5.7a5.4 5.4 0 0 0-7.7 0L12 6.8l-1.1-1.1a5.4 5.4 0 0 0-7.7 7.7l1.1 1.1L12 22l7.7-7.5 1.1-1.1a5.4 5.4 0 0 0 0-7.7Z"></path>
                          </svg>
                        </button>
                      {% endif %}

                      {% if card_block.settings.show_quick_add or card_block.settings.show_quick_view %}
                        <div class="premium-product-card__media-actions">
                          {% if card_block.settings.show_quick_view %}
                            <button
                              class="premium-product-card__round-action"
                              type="button"
                              aria-label="Quick view {{ product.title | escape }}"
                              data-quick-view
                            >
                              <svg aria-hidden="true" viewBox="0 0 24 24">
                                <path d="M2.5 12s3.4-6 9.5-6 9.5 6 9.5 6-3.4 6-9.5 6-9.5-6-9.5-6Z"></path><circle cx="12" cy="12" r="2.7"></circle>
                              </svg>
                            </button>
                          {% endif %}
                          {% if card_block.settings.show_quick_add %}
                            {% if simple_product and current_variant.available %}
                              <button
                                class="premium-product-card__round-action"
                                type="button"
                                aria-label="Quick add {{ product.title | escape }}"
                                data-quick-add
                                data-variant-id="{{ current_variant.id }}"
                              >
                                <svg aria-hidden="true" viewBox="0 0 24 24">
                                  <path d="M4 7h16l-1 13H5L4 7Z"></path><path d="M9 9V5a3 3 0 0 1 6 0v4M12 11v5m-2.5-2.5h5"></path>
                                </svg>
                              </button>
                            {% else %}
                              <a
                                class="premium-product-card__round-action"
                                href="{{ product.url }}"
                                aria-label="Choose options for {{ product.title | escape }}"
                              >
                                <svg aria-hidden="true" viewBox="0 0 24 24">
                                  <path d="M4 7h16l-1 13H5L4 7Z"></path><path d="M9 9V5a3 3 0 0 1 6 0v4"></path>
                                </svg>
                              </a>
                            {% endif %}
                          {% endif %}
                        </div>
                      {% endif %}
                    </div>

                    <div class="premium-product-card__content">
                      {% if card_block.settings.show_vendor and product.vendor != blank %}
                        <p class="premium-product-card__vendor">{{ product.vendor | escape }}</p>
                      {% endif %}
                      <h3 class="premium-product-card__title">
                        <a class="premium-product-card__title-link" href="{{ product.url }}">
                          {{- product.title | escape -}}
                        </a>
                      </h3>

                      {% if card_block.settings.show_rating and rating_value != blank %}
                        <div
                          class="premium-product-card__rating"
                          aria-label="Rated {{ rating_value }} out of {{ rating_max }}"
                        >
                          <span class="premium-product-card__stars" style="--rating-percent: {{ rating_percent }}%;"
                            >★★★★★</span
                          >
                          <span class="premium-product-card__rating-count">({{ rating_count }})</span>
                        </div>
                      {% endif %}

                      <div class="premium-product-card__price-row">
                        <span class="premium-product-card__price">
                          {%- if product.price_varies %}From {% endif -%}
                          {{- product.price | money -}}
                        </span>
                        {% if on_sale -%}
                          <span class="premium-product-card__compare-price">{{ compare_price | money }}</span>
                        {%- endif %}
                      </div>

                      {% if show_low_inventory -%}
                        <span class="premium-product-card__inventory-text"
                          >Low stock — {{ current_variant.inventory_quantity }} remaining</span
                        >
                      {%- endif %}

                      {% if card_block.settings.show_add_button %}
                        {% if simple_product %}
                          <button
                            class="premium-product-card__add"
                            type="button"
                            data-add-to-cart
                            data-variant-id="{{ current_variant.id }}"
                            {% unless current_variant.available %}
                              disabled
                            {% endunless %}
                          >
                            {% if current_variant.available -%}
                              {{- card_block.settings.add_button_text | default: 'Add to cart' | escape -}}
                            {%- else -%}
                              Sold out
                            {%- endif %}
                          </button>
                        {% else %}
                          <a class="premium-product-card__options" href="{{ product.url }}">
                            {{- card_block.settings.options_button_text | default: 'Choose options' | escape -}}
                          </a>
                        {% endif %}
                      {% endif %}
                    </div>
                  </article>
                </div>
              {% endfor %}
            </div>
          </div>

          {% if slider_block.settings.arrows_enable %}
            <button
              class="premium-product-slider__arrow premium-product-slider__arrow--previous premium-product-slider__arrow--{{ slider_block.settings.arrow_style | default: 'circle' }}"
              type="button"
              aria-label="Previous products"
              data-slider-previous
            >
              <svg aria-hidden="true" viewBox="0 0 20 20">
                <path d="m12.5 4-6 6 6 6"></path>
              </svg>
            </button>
            <button
              class="premium-product-slider__arrow premium-product-slider__arrow--next premium-product-slider__arrow--{{ slider_block.settings.arrow_style | default: 'circle' }}"
              type="button"
              aria-label="Next products"
              data-slider-next
            >
              <svg aria-hidden="true" viewBox="0 0 20 20">
                <path d="m7.5 4 6 6-6 6"></path>
              </svg>
            </button>
          {% endif %}

          {% if slider_block.settings.dots_enable and slider_block.settings.dots_position == 'bottom' %}
            <div
              class="premium-product-slider__dots premium-product-slider__dots--bottom"
              data-slider-dots
              aria-label="Slider pagination"
            ></div>
          {% endif %}
        </div>
      {% else %}
        <div class="premium-product-slider__empty">
          Select a collection to display products.
        </div>
      {% endif %}

      {% if button_block.settings.enable and button_block.settings.text != blank %}
        <div class="premium-product-slider__footer" {{ button_block.shopify_attributes }}>
          <a
            class="premium-product-slider__section-button"
            href="{{ button_block.settings.link | default: section.settings.collection.url | default: routes.all_products_collection_url }}"
          >
            {{- button_block.settings.text | escape -}}
          </a>
        </div>
      {% endif %}
    </div>

    {% if card_block.settings.show_quick_view %}
      <div class="premium-product-slider__quick-view-shell" data-quick-view-shell aria-hidden="true" inert>
        <button
          class="premium-product-slider__quick-view-overlay"
          type="button"
          aria-label="Close quick view"
          data-quick-view-close
          tabindex="-1"
        ></button>
        <aside
          class="premium-product-slider__quick-view"
          data-quick-view-modal
          role="dialog"
          aria-modal="true"
          aria-label="Product quick view"
          tabindex="-1"
        >
          <button
            class="premium-product-slider__quick-view-close"
            type="button"
            aria-label="Close quick view"
            data-quick-view-close
          >
            <svg aria-hidden="true" viewBox="0 0 20 20">
              <path d="m4 4 12 12M16 4 4 16"></path>
            </svg>
          </button>
          <img
            class="premium-product-slider__quick-view-image"
            data-quick-view-image
            alt=""
            loading="lazy"
            width="600"
            height="700"
          >
          <div class="premium-product-slider__quick-view-content">
            <h3 class="premium-product-slider__quick-view-title" data-quick-view-title></h3>
            <div class="premium-product-slider__quick-view-price" data-quick-view-price></div>
            <button class="premium-product-card__add" type="button" data-quick-view-add hidden>
              {{ card_block.settings.add_button_text | default: 'Add to cart' | escape }}
            </button>
            <a class="premium-product-slider__quick-view-link" data-quick-view-link>View full product details</a>
          </div>
        </aside>
      </div>
    {% endif %}

    <div class="premium-product-slider__status" data-slider-status role="status" aria-live="polite"></div>
  </section>
</premium-product-slider>

<script>
  (() => {
    class PremiumProductSlider extends HTMLElement {
      connectedCallback() {
        if (this.initialized) return;
        this.initialized = true;
        this.controller = new AbortController();
        this.signal = this.controller.signal;
        this.track = this.querySelector('[data-slider-track]');
        this.slides = Array.from(this.querySelectorAll('[data-slider-slide]'));
        this.previousButton = this.querySelector('[data-slider-previous]');
        this.nextButton = this.querySelector('[data-slider-next]');
        this.dotsContainers = Array.from(this.querySelectorAll('[data-slider-dots]'));
        this.autoplayTimer = null;
        this.statusTimer = null;
        this.dragging = false;
        this.dragMoved = false;
        this.quickViewTrigger = null;

        this.setupSlider();
        this.setupProductActions();
        this.setupQuickView();
        this.restoreWishlist();
      }

      disconnectedCallback() {
        if (this.controller) this.controller.abort();
        if (this.resizeObserver) this.resizeObserver.disconnect();
        window.clearInterval(this.autoplayTimer);
        window.clearTimeout(this.statusTimer);
        document.documentElement.style.removeProperty('overflow');
        this.initialized = false;
      }

      setupSlider() {
        if (!this.track || !this.slides.length) return;

        if (this.previousButton)
          this.previousButton.addEventListener('click', () => this.navigate(-1), { signal: this.signal });
        if (this.nextButton) this.nextButton.addEventListener('click', () => this.navigate(1), { signal: this.signal });
        this.track.addEventListener('scroll', () => this.requestUpdate(), { passive: true, signal: this.signal });
        this.track.addEventListener(
          'keydown',
          (event) => {
            if (event.key === 'ArrowLeft') {
              event.preventDefault();
              this.navigate(-1);
            } else if (event.key === 'ArrowRight') {
              event.preventDefault();
              this.navigate(1);
            }
          },
          { signal: this.signal },
        );

        if (this.dataset.mouseDrag === 'true') this.setupMouseDrag();

        if (this.dataset.pauseHover === 'true') {
          this.addEventListener('mouseenter', () => this.stopAutoplay(), { signal: this.signal });
          this.addEventListener('mouseleave', () => this.startAutoplay(), { signal: this.signal });
          this.addEventListener('focusin', () => this.stopAutoplay(), { signal: this.signal });
          this.addEventListener('focusout', () => this.startAutoplay(), { signal: this.signal });
        }

        document.addEventListener(
          'visibilitychange',
          () => {
            if (document.hidden) this.stopAutoplay();
            else this.startAutoplay();
          },
          { signal: this.signal },
        );

        this.resizeObserver = new ResizeObserver(() => this.rebuildSlider());
        this.resizeObserver.observe(this.track);
        this.rebuildSlider();
        this.startAutoplay();
      }

      setupMouseDrag() {
        this.track.addEventListener(
          'pointerdown',
          (event) => {
            if (event.pointerType !== 'mouse' || event.button !== 0 || event.target.closest('button')) return;
            this.dragging = true;
            this.dragMoved = false;
            this.dragStartX = event.clientX;
            this.dragStartScroll = this.track.scrollLeft;
            this.track.classList.add('is-dragging');
            this.track.setPointerCapture(event.pointerId);
            this.stopAutoplay();
          },
          { signal: this.signal },
        );

        this.track.addEventListener(
          'pointermove',
          (event) => {
            if (!this.dragging) return;
            const distance = event.clientX - this.dragStartX;
            if (Math.abs(distance) > 4) this.dragMoved = true;
            this.track.scrollLeft = this.dragStartScroll - distance;
          },
          { signal: this.signal },
        );

        const endDrag = (event) => {
          if (!this.dragging) return;
          this.dragging = false;
          this.track.classList.remove('is-dragging');
          if (this.track.hasPointerCapture(event.pointerId)) this.track.releasePointerCapture(event.pointerId);
          this.startAutoplay();
        };

        this.track.addEventListener('pointerup', endDrag, { signal: this.signal });
        this.track.addEventListener('pointercancel', endDrag, { signal: this.signal });
        this.track.addEventListener(
          'click',
          (event) => {
            if (this.dragMoved) {
              event.preventDefault();
              event.stopPropagation();
              this.dragMoved = false;
            }
          },
          { capture: true, signal: this.signal },
        );
      }

      isSliderEnabled() {
        if (window.matchMedia('(max-width: 749px)').matches) return this.dataset.mobileSlider === 'true';
        if (window.matchMedia('(max-width: 989px)').matches) return this.dataset.tabletSlider === 'true';
        return this.dataset.desktopSlider === 'true';
      }

      rebuildSlider() {
        if (!this.track) return;
        const maxScroll = Math.max(0, this.track.scrollWidth - this.track.clientWidth);
        this.pageCount = maxScroll > 2 ? Math.ceil(maxScroll / Math.max(1, this.track.clientWidth)) + 1 : 1;
        this.buildDots();
        this.updateControls();
      }

      buildDots() {
        this.dotsContainers.forEach((container) => {
          container.replaceChildren();
          if (!this.isSliderEnabled() || this.pageCount < 2) {
            container.hidden = true;
            return;
          }
          container.hidden = false;
          for (let index = 0; index < this.pageCount; index += 1) {
            const dot = document.createElement('button');
            dot.className = 'premium-product-slider__dot';
            dot.type = 'button';
            dot.setAttribute('aria-label', `Go to product page ${index + 1}`);
            dot.addEventListener('click', () => this.goToPage(index));
            container.appendChild(dot);
          }
        });
      }

      requestUpdate() {
        if (this.updateFrame) return;
        this.updateFrame = requestAnimationFrame(() => {
          this.updateFrame = null;
          this.updateControls();
        });
      }

      updateControls() {
        if (!this.track) return;
        const maxScroll = Math.max(0, this.track.scrollWidth - this.track.clientWidth);
        const activePage =
          maxScroll > 0
            ? Math.min(this.pageCount - 1, Math.round(this.track.scrollLeft / Math.max(1, this.track.clientWidth)))
            : 0;
        this.activePage = activePage;
        const infinite = this.dataset.infinite === 'true';
        const enabled = this.isSliderEnabled() && maxScroll > 2;

        if (this.previousButton) this.previousButton.disabled = !enabled || (!infinite && this.track.scrollLeft <= 2);
        if (this.nextButton)
          this.nextButton.disabled = !enabled || (!infinite && this.track.scrollLeft >= maxScroll - 2);

        this.dotsContainers.forEach((container) => {
          Array.from(container.children).forEach((dot, index) => {
            dot.classList.toggle('is-active', index === activePage);
            dot.setAttribute('aria-current', index === activePage ? 'true' : 'false');
          });
        });
      }

      navigate(direction) {
        if (!this.track || !this.isSliderEnabled()) return;
        const maxScroll = Math.max(0, this.track.scrollWidth - this.track.clientWidth);
        const infinite = this.dataset.infinite === 'true';
        let target = this.track.scrollLeft + this.track.clientWidth * direction;
        if (direction > 0 && target > maxScroll - 2) target = infinite ? 0 : maxScroll;
        if (direction < 0 && target < 2) target = infinite ? maxScroll : 0;
        this.scrollTo(target);
      }

      goToPage(index) {
        if (!this.track) return;
        const maxScroll = Math.max(0, this.track.scrollWidth - this.track.clientWidth);
        this.scrollTo(Math.min(maxScroll, index * this.track.clientWidth));
      }

      scrollTo(left) {
        const behavior = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth';
        if (this.dataset.animation === 'fade') {
          this.track.classList.add('is-fading');
          window.setTimeout(() => {
            this.track.scrollTo({ left, behavior });
            window.setTimeout(() => this.track.classList.remove('is-fading'), 190);
          }, 120);
        } else {
          this.track.scrollTo({ left, behavior });
        }
      }

      startAutoplay() {
        if (
          this.autoplayTimer ||
          this.dataset.autoplay !== 'true' ||
          !this.isSliderEnabled() ||
          this.pageCount < 2 ||
          window.matchMedia('(prefers-reduced-motion: reduce)').matches
        )
          return;
        const speed = Math.max(2, Number(this.dataset.autoplaySpeed || 5)) * 1000;
        this.autoplayTimer = window.setInterval(() => this.navigate(1), speed);
      }

      stopAutoplay() {
        window.clearInterval(this.autoplayTimer);
        this.autoplayTimer = null;
      }

      setupProductActions() {
        this.addEventListener(
          'click',
          (event) => {
            const addButton = event.target.closest('[data-add-to-cart], [data-quick-add]');
            if (addButton) {
              event.preventDefault();
              this.addVariant(addButton.dataset.variantId, addButton);
              return;
            }

            const wishlistButton = event.target.closest('[data-wishlist-button]');
            if (wishlistButton) {
              event.preventDefault();
              this.toggleWishlist(wishlistButton);
            }
          },
          { signal: this.signal },
        );
      }

      async addVariant(variantId, button) {
        if (!variantId || !button || button.disabled) return;
        const originalText = button.textContent;
        button.disabled = true;
        if (originalText.trim()) button.textContent = 'Adding…';

        try {
          const root = window.Shopify && Shopify.routes ? Shopify.routes.root : '/';
          const response = await fetch(`${root}cart/add.js`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({ items: [{ id: Number(variantId), quantity: 1 }] }),
          });
          if (!response.ok) throw new Error('Unable to add product');
          const cartResponse = await fetch(`${root}cart.js`, { headers: { Accept: 'application/json' } });
          const cart = cartResponse.ok ? await cartResponse.json() : null;
          if (cart) document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart } }));
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          this.showStatus('Product added to your cart.');
          if (originalText.trim()) button.textContent = 'Added';
          window.setTimeout(() => {
            button.textContent = originalText;
            button.disabled = false;
          }, 1200);
        } catch (error) {
          this.showStatus('This product could not be added. Please try again.');
          button.textContent = originalText;
          button.disabled = false;
        }
      }

      toggleWishlist(button) {
        const handle = button.dataset.productHandle;
        if (!handle) return;
        let wishlist = [];
        try {
          wishlist = JSON.parse(localStorage.getItem('premium_product_wishlist') || '[]');
        } catch (error) {
          wishlist = [];
        }
        const active = !wishlist.includes(handle);
        wishlist = active ? [...wishlist, handle] : wishlist.filter((item) => item !== handle);
        try {
          localStorage.setItem('premium_product_wishlist', JSON.stringify(wishlist));
        } catch (error) {
          // Wishlist app classes and data attributes remain available if storage is blocked.
        }
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
        this.showStatus(active ? 'Added to wishlist.' : 'Removed from wishlist.');
      }

      restoreWishlist() {
        let wishlist = [];
        try {
          wishlist = JSON.parse(localStorage.getItem('premium_product_wishlist') || '[]');
        } catch (error) {
          wishlist = [];
        }
        this.querySelectorAll('[data-wishlist-button]').forEach((button) => {
          const active = wishlist.includes(button.dataset.productHandle);
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }

      setupQuickView() {
        this.quickViewShell = this.querySelector('[data-quick-view-shell]');
        this.quickViewModal = this.querySelector('[data-quick-view-modal]');
        if (!this.quickViewShell || !this.quickViewModal) return;

        this.querySelectorAll('[data-quick-view]').forEach((button) => {
          button.addEventListener('click', () => this.openQuickView(button), { signal: this.signal });
        });
        this.querySelectorAll('[data-quick-view-close]').forEach((button) => {
          button.addEventListener('click', () => this.closeQuickView(), { signal: this.signal });
        });
        document.addEventListener(
          'keydown',
          (event) => {
            if (event.key === 'Escape' && this.classList.contains('quick-view-open')) this.closeQuickView();
          },
          { signal: this.signal },
        );
      }

      openQuickView(trigger) {
        const card = trigger.closest('[data-product-card]');
        if (!card) return;
        this.quickViewTrigger = trigger;
        const image = this.quickViewShell.querySelector('[data-quick-view-image]');
        const title = this.quickViewShell.querySelector('[data-quick-view-title]');
        const price = this.quickViewShell.querySelector('[data-quick-view-price]');
        const link = this.quickViewShell.querySelector('[data-quick-view-link]');
        const add = this.quickViewShell.querySelector('[data-quick-view-add]');

        image.src = card.dataset.productImage || '';
        image.alt = card.dataset.productTitle || '';
        title.textContent = card.dataset.productTitle || '';
        price.textContent = card.dataset.productPrice || '';
        link.href = card.dataset.productUrl || '#';
        add.hidden = !card.dataset.variantId;
        add.dataset.variantId = card.dataset.variantId || '';
        add.onclick = () => this.addVariant(add.dataset.variantId, add);

        this.classList.add('quick-view-open');
        this.quickViewShell.removeAttribute('inert');
        this.quickViewShell.setAttribute('aria-hidden', 'false');
        document.documentElement.style.overflow = 'hidden';
        requestAnimationFrame(() => this.quickViewModal.focus());
      }

      closeQuickView() {
        if (!this.quickViewShell) return;
        this.classList.remove('quick-view-open');
        this.quickViewShell.setAttribute('aria-hidden', 'true');
        this.quickViewShell.setAttribute('inert', '');
        document.documentElement.style.removeProperty('overflow');
        if (this.quickViewTrigger) this.quickViewTrigger.focus();
      }

      showStatus(message) {
        const status = this.querySelector('[data-slider-status]');
        if (!status) return;
        status.textContent = message;
        status.classList.add('is-visible');
        window.clearTimeout(this.statusTimer);
        this.statusTimer = window.setTimeout(() => status.classList.remove('is-visible'), 2600);
      }
    }

    if (!customElements.get('premium-product-slider')) {
      customElements.define('premium-product-slider', PremiumProductSlider);
    }
  })();
</script>

