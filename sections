                                  {% for grandchild_link in child_link.links %}
                                    <li>
                                      <a class="premium-header__mega-child{% if grandchild_link.current %} is-active{% endif %}" href="{{ grandchild_link.url }}"{% if grandchild_link.current %} aria-current="page"{% endif %}>{{ grandchild_link.title | escape }}</a>
                                    </li>
                                  {% endfor %}
                                </ul>
                              {% endif %}
                            </div>
                          {% endfor %}
                        {% else %}
                          <div class="premium-header__mega-column">
                            <a class="premium-header__mega-title" href="{{ link.url }}">Explore {{ link.title | escape }}</a>
                          </div>
                        {% endif %}
                      </div>

                      {% if mega_panel_style == 'benefits' %}
                        <aside
                          class="premium-header__mega-benefits"
                          style="--mega-benefit-background: {{ mega_block.settings.benefits_background }}; --mega-benefit-text: {{ mega_block.settings.benefits_text_color }}; --mega-benefit-accent: {{ mega_block.settings.benefits_accent_color }}; --mega-benefit-icon: {{ mega_block.settings.benefits_icon_color }};"
