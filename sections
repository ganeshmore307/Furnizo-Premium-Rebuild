<style>
  .faz-testi { padding: 48px 24px; text-align:center; }
  .faz-testi-heading { font-family: Georgia, 'Playfair Display', serif; font-size: 20px; letter-spacing: 2px; text-transform: uppercase; margin: 0 0 30px; color:#3f2a24; }
  .faz-testi-track { display:flex; overflow:hidden; max-width: 1100px; margin: 0 auto; }
  .faz-testi-slide { min-width: 100%; padding: 0 40px; }
  .faz-testi-quote { font-family: Georgia, serif; font-size: 40px; color: #d9c3a0; line-height: 0; display:block; margin-bottom: 8px; }
  .faz-testi-review { font-size: 14px; line-height: 1.7; color: #4b403a; max-width: 560px; margin: 0 auto 14px; }
