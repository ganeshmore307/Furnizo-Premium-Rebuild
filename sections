      async refreshCart(renderDrawer = false) {
        if (!this.cartCounts.length && !renderDrawer) return null;
        try {
          const cartUrl = this.dataset.cartUrl || `${window.Shopify && Shopify.routes ? Shopify.routes.root : '/'}cart.js`;
