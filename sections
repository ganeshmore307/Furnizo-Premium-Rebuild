{% liquid
  assign empty_array = '' | split: ','
  assign slider_blocks = section.blocks | where: 'type', 'slider_controls'
  assign card_blocks = section.blocks | where: 'type', 'card_style'
  assign button_blocks = section.blocks | where: 'type', 'section_button'
  assign slider_block = slider_blocks.first
  assign card_block = card_blocks.first
  assign button_block = button_blocks.first

  assign collection_products = empty_array
  if section.settings.collection != blank
    assign collection_products = section.settings.collection.products
  endif

  assign products_to_show = collection_products

  case section.settings.sort_order
    when 'title_asc'
      assign products_to_show = products_to_show | sort: 'title'
    when 'title_desc'
      assign products_to_show = products_to_show | sort: 'title' | reverse
    when 'price_asc'
      assign products_to_show = products_to_show | sort: 'price'
    when 'price_desc'
      assign products_to_show = products_to_show | sort: 'price' | reverse
    when 'newest'
      assign products_to_show = products_to_show | sort: 'published_at' | reverse
    when 'oldest'
      assign products_to_show = products_to_show | sort: 'published_at'
  endcase

  assign rendered_count = products_to_show.size | at_most: section.settings.max_products
  assign image_loading = 'eager'
  if section.settings.lazy_load
    assign image_loading = 'lazy'
  endif

  assign card_background = card_block.settings.card_background | default: '#ffffff'
  assign title_color = card_block.settings.title_color | default: '#28211e'
  assign price_color = card_block.settings.price_color | default: '#6d252a'
  assign compare_color = card_block.settings.compare_color | default: '#9a928e'
  assign card_border_color = card_block.settings.border_color | default: '#eee8e4'
  assign sale_background = card_block.settings.sale_background | default: '#7b1d25'
  assign sale_text = card_block.settings.sale_text | default: '#ffffff'
  assign wishlist_color = card_block.settings.wishlist_color | default: '#6c5753'
  assign quick_add_background = card_block.settings.quick_add_background | default: '#ffffff'
  assign quick_add_color = card_block.settings.quick_add_color | default: '#28211e'
  assign rating_color = card_block.settings.rating_color | default: '#b88942'

  case card_block.settings.card_shadow
    when 'soft'
      assign card_shadow = '0 8px 26px rgba(46, 30, 25, 0.07)'
    when 'medium'
      assign card_shadow = '0 12px 34px rgba(46, 30, 25, 0.12)'
    else
      assign card_shadow = 'none'
  endcase

  case card_block.settings.hover_shadow
    when 'soft'
      assign hover_shadow = '0 14px 36px rgba(46, 30, 25, 0.12)'
    when 'strong'
      assign hover_shadow = '0 20px 48px rgba(46, 30, 25, 0.19)'
    else
      assign hover_shadow = card_shadow
  endcase

  case slider_block.settings.arrow_shadow
    when 'soft'
      assign arrow_shadow = '0 5px 18px rgba(38, 25, 21, 0.13)'
    when 'strong'
      assign arrow_shadow = '0 8px 24px rgba(38, 25, 21, 0.23)'
    else
      assign arrow_shadow = 'none'
  endcase
%}

