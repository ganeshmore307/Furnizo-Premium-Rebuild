<!-- /snippets/breadcrumb.liquid -->
{% comment %}
Documentation - http://docs.shopify.com/support/your-website/navigation/creating-a-breadcrumb-navigation
{% endcomment %}

{% unless template == 'index' %}
{% if settings.enable_rtl_mode %}
<div class="bread-crumb">
  {% if template contains 'product' %}
	<strong>{{ product.title }}</strong>
  {% if collection %}
  {% if collection.handle %}
  {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
  <a href="{{ collection.url}}"><i class="fa fa-angle-left" aria-hidden="true"></i>{{collection.title}}</a>
  {% endif %}
  {% endif %}
  

  {% elsif template contains 'collection' and collection.handle %}
  {% if current_tags %}
  {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
  {{ collection.title | link_to: url }}
  {% else %}
  <strong>{{ collection.title }}</strong>
  {% endif %}

  {% elsif template == 'blog' %}
  {% if current_tags %}
  {{ blog.title | link_to: blog.url }}
  {% else %}
  <strong>{{ blog.title }}</strong>
  {% endif %}

  {% elsif template == 'article' %}
  <strong>{{ article.title }}</strong>
  <a href="{{ blog.url}}"><i class="fa fa-angle-left" aria-hidden="true"></i> {{blog.title}}</a>
  

  {% elsif template contains 'page' %}
  <strong>{{ page.title }}</strong>

  {% else %}
  <strong>{{ page_title }}</strong>

  {% endif %}
  <a href="/" title="{{ 'general.breadcrumbs.home_link_title' | t }}"><i class="fa fa-angle-left" aria-hidden="true"></i>{{ 'general.breadcrumbs.home' | t }}</a>

</div>
{% else %}
<div class="bread-crumb">
  <a href="/" title="{{ 'general.breadcrumbs.home_link_title' | t }}">{{ 'general.breadcrumbs.home' | t }}<i class="fa fa-angle-right" aria-hidden="true"></i></a>
  {% if template contains 'product' %}

  {% if collection %}
  {% if collection.handle %}
  {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
  <a href="{{ collection.url}}">{{collection.title}} <i class="fa fa-angle-right" aria-hidden="true"></i></a>
  {% endif %}
  {% endif %}
  <strong>{{ product.title }}</strong>

  {% elsif template contains 'collection' and collection.handle %}
  {% if current_tags %}
  {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
  {{ collection.title | link_to: url }}
  <strong>{{ current_tags | join: " + " }}</strong>
  {% else %}
  <strong>{{ collection.title }}</strong>
  {% endif %}

  {% elsif template == 'blog' %}
  {% if current_tags %}
  {{ blog.title | link_to: blog.url }}
  <strong>{{ current_tags | join: " + " }}</strong>
  {% else %}
  <strong>{{ blog.title }}</strong>
  {% endif %}

  {% elsif template == 'article' %}
  <a href="{{ blog.url}}">{{blog.title}} <i class="fa fa-angle-right" aria-hidden="true"></i></a>
  <strong>{{ article.title }}</strong>

  {% elsif template contains 'page' %}
  <strong>{{ page.title }}</strong>

  {% else %}
  <strong>{{ page_title }}</strong>

  {% endif %}
</div>

{% endif %}
{% endunless %}



<div class="box-change-langue">
  <div class="top-lanngue">
    <a class="title-langue" data-toggle="collapse" href="#collapseExample">
      {{settings.title-change-language}}
    </a>
  </div>
  <div id="collapseExample" class="collapse" style="">
    <ul class="mb-0 list-unstyled ">
      {% for link in linklists[settings.menu-change-language].links %}
      <li><a href="{{link.url}}" title="{{link.title}}" class="text-uppercase">{{link.title}}</a></li>
      {% endfor %}
    </ul>
  </div>
</div>
<div class="banner_sidebar ">
  <a href="{{settings.banner_url}}" target="_blank">
    <img class="w-100" src="{% if settings.banner_sidebar != blank %} {{settings.banner_sidebar |img_url :'master'}} {% else %} //via.placeholder.com/320x480{% endif %}">
  </a>
</div>
<section class="widget widget-category widget_product_categories filter-brand">
  <div class="widget-title">
    <h2 class="mb-0">{{settings.shop_by_brand_title}}</h2>
  </div>
  
  <ul class="list-none list-brand">
    {% for product_vendor in collection.all_vendors %}
    <li class="cat-item">

      {{ product_vendor | link_to_vendor }} 
    </li>
    {% endfor %}
  </ul>
  <!-- /.product-categories -->
</section>
<div class="filter-color widget widget-category widget_product_categories filter-tag">
  <div class="widget-title">
    <h2 class="mb-0">{{settings.shop_by_color_title}}</h2>
  </div>

  <ul class="list-none list_color {% if section.settings.filter_layout == 'filter_collapse' %}color_collapse{% endif%}">
    {% assign tags = settings.shop_by_color_list_tags | split: ',' %}

    {% for t in tags %}
    {% assign tag = t | strip %}
    {% assign tag_value = tag | handleize %}
    <li class="cat-item{% if current_tags contains tag %} current-cat{% endif %}">
      <input type="checkbox" value="{{ tag_value | split: '|' | first }}" {% if current_tags contains tag %}checked{% endif %}/>
      <a href="javascript:void(0)" title="{{tag}}" style="background: {{tag}}" class=" {% if current_tags contains tag %}active{% endif %}">
        {% if section.settings.filter_layout == 'filter_collapse' %}<span>{{tag}}</span>{% endif %}
      </a>
    </li>
    {% endfor %}

  </ul>

  <!-- /.product-categories -->
</div>
<section class="filter-price filter-tag">
  <div class="widget-title">
    <h2 class="mb-0">{{settings.shop_by_price_title}}</h2>
  </div>
  
  <ul class="list-none list-price">
    {% assign tags = settings.shop_by_price_list_tags | split: ',' %}
    {% for t in tags %}
    {% assign tag = t | strip %}
    {% assign tag_value = tag | handleize %}
    <li class="cat-item{% if current_tags contains tag %} current-cat{% endif %}">
      <input type="checkbox" value="{{ tag_value | split: '|' | first }}" {% if current_tags contains tag %}checked{% endif %}/>
      <a href="javascript:void(0)" title="{{tag}}" class=" {% if current_tags contains tag %}active{% endif %}">{{tag}}</a>
    </li>
    {% endfor %}
  </ul>
  <!-- /.product-categories -->
</section>
<section class=" filter-size filter-tag">
  <div class="widget-title">
    <h2 class="mb-0">{{settings.shop_by_size_title}}</h2>
  </div>
  <ul class="list-none list-size">
    {% assign tags = settings.shop_by_size_list_tags | split: ',' %}
    {% for t in tags %}
    {% assign tag = t | strip %}
    {% assign tag_value = tag | handleize %}
    <li class="cat-item{% if current_tags contains tag %} current-cat{% endif %}">
      <input type="checkbox" value="{{ tag_value | split: '|' | first }}" {% if current_tags contains tag %}checked{% endif %}/>
      <a href="javascript:void(0)" title="{{tag}}" class=" {% if current_tags contains tag %}active{% endif %}">{{tag}}</a>
    </li>
    {% endfor %}
  </ul>
  <!-- /.product-categories -->
</section>
